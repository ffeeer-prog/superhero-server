            remove weakness from arg-1
            set game mode of arg-1 to survival
            send "{@event_prefix}&a&l✓ RESURRECTED! &7You have been brought back to life!" to arg-1
            make console execute command "playsound minecraft:entity.player.levelup master %arg-1% ~ ~ ~ 1 1.2"
