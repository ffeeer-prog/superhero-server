function pdRewardTeam(team: text):
    set {_rep} to {pd.active.rep_reward}
    set {_xp} to {pd.active.xp_reward}
    set {_bucks} to {pd.active.bucks_reward}
    set {_list::*} to {pd.active.attackers::*}
    if {_team} is "defenders":
        set {_list::*} to {pd.active.defenders::*}
    else if {_team} is "team1":
        set {_list::*} to {pd.active.team1::*}
    else if {_team} is "team2":
        set {_list::*} to {pd.active.team2::*}
    else if {_team} is "survivors":
        set {_list::*} to {pd.active.players::*}
    loop all players:
        if {_list::*} contains loop-player's uuid:
            # BUG 3 FIX: For survivors reward mode, only reward those NOT in dead list
            if {_team} is "survivors":
                if {pd.active.dead::*} contains loop-player's uuid:
                    continue
            pdInit(loop-player)
            add {_rep} to {pd.%loop-player's uuid%.reputation}
            if {_xp} > 0:
                set {_curlevel} to loop-player's level
                set loop-player's level to {_curlevel} + {_xp}
            if {_bucks} > 0:
                make console execute command "bucks give %loop-player% %{_bucks}%"
            pdUpdateStars(loop-player)
            pdSyncMeta(loop-player)
            set {_rewardmsg} to "{@event_prefix}&6&l+%{_rep}% Reputation &7and &6&l+%{_xp}% XP Levels"
            if {_bucks} > 0:
                set {_rewardmsg} to "%{_rewardmsg}% &7and &6&l%{_bucks}% Bucks"
            set {_rewardmsg} to "%{_rewardmsg}% &7for winning!"
            send {_rewardmsg} to loop-player

function pdPenaltyTeam(team: text):
    set {_list::*} to {pd.active.team1::*}
    if {_team} is "team2":
        set {_list::*} to {pd.active.team2::*}
    else if {_team} is "attackers":
        set {_list::*} to {pd.active.attackers::*}
    else if {_team} is "defenders":
        set {_list::*} to {pd.active.defenders::*}
    loop all players:
        if {_list::*} contains loop-player's uuid:
            pdInit(loop-player)
            set {_loss} to random integer between 1 and 3
            remove {_loss} from {pd.%loop-player's uuid%.reputation}
            if {pd.%loop-player's uuid%.reputation} < 0:
                set {pd.%loop-player's uuid%.reputation} to 0
            pdUpdateStars(loop-player)
            pdSyncMeta(loop-player)
            send "{@event_prefix}&c&l-%{_loss}% Reputation &7for losing." to loop-player

function pdRewardTopKillers():
    set {_rep} to {pd.active.rep_reward}
    set {_xp} to {pd.active.xp_reward}
    set {_bucks} to {pd.active.bucks_reward}
    # PARTICIPANTS FIX: Use participants list for complete leaderboard
    set {_allplayers::*} to {pd.active.participants::*}
    # Initialize 0 kills for participants without kills
    loop {_allplayers::*}:
        if {pd.active.kills.%loop-value%} is not set:
            set {pd.active.kills.%loop-value%} to 0
    set {_top1} to ""
    set {_top2} to ""
    set {_top3} to ""
    set {_top1kills} to 0
    set {_top2kills} to 0
    set {_top3kills} to 0
    loop {_allplayers::*}:
        set {_uuid} to loop-value
        set {_kills} to {pd.active.kills.%{_uuid}%}
        if {_kills} is not set:
            set {_kills} to 0
        if {_kills} > {_top1kills}:
            set {_top3} to {_top2}
            set {_top3kills} to {_top2kills}
            set {_top2} to {_top1}
            set {_top2kills} to {_top1kills}
            set {_top1} to {_uuid}
            set {_top1kills} to {_kills}
        else if {_kills} > {_top2kills}:
            set {_top3} to {_top2}
            set {_top3kills} to {_top2kills}
            set {_top2} to {_uuid}
            set {_top2kills} to {_kills}
        else if {_kills} > {_top3kills}:
            set {_top3} to {_uuid}
            set {_top3kills} to {_kills}
    set {_bonus1} to {_rep} * 3
    set {_bonus2} to {_rep} * 2
    set {_bonus3} to {_rep}
    set {_bucksbonus1} to {_bucks} * 3
    set {_bucksbonus2} to {_bucks} * 2
    set {_bucksbonus3} to {_bucks}
    if {_top1} is not "":
        set {_p1} to {_top1} parsed as offline player
        if {_p1} is online:
            pdInit({_p1})
            add {_bonus1} to {pd.%{_top1}%.reputation}
            if {_xp} > 0:
                set {_curlevel} to {_p1}'s level
                set {_p1}'s level to {_curlevel} + {_xp}
            if {_bucksbonus1} > 0:
                make console execute command "bucks give % {_p1}% %{_bucksbonus1}%"
            pdUpdateStars({_p1})
            pdSyncMeta({_p1})
            broadcast "{@event_prefix}&6&l1st Place: &e%{_p1}% &7with &c%{_top1kills}% &7kills! &6+%{_bonus1}% rep"
            send "{@event_prefix}&6&l🥇 1st Place! &7+&e%{_bonus1}% &7rep for &c%{_top1kills}% &7kills!" to {_p1}
    if {_top2} is not "":
        set {_p2} to {_top2} parsed as offline player
        if {_p2} is online:
            pdInit({_p2})
            add {_bonus2} to {pd.%{_top2}%.reputation}
            if {_xp} > 0:
                set {_curlevel} to {_p2}'s level
                set {_p2}'s level to {_curlevel} + {_xp}
            if {_bucksbonus2} > 0:
                make console execute command "bucks give % {_p2}% %{_bucksbonus2}%"
            pdUpdateStars({_p2})
            pdSyncMeta({_p2})
            broadcast "{@event_prefix}&7&l2nd Place: &e%{_p2}% &7with &c%{_top2kills}% &7kills! &6+%{_bonus2}% rep"
            send "{@event_prefix}&7&l🥈 2nd Place! &7+&e%{_bonus2}% &7rep for &c%{_top2kills}% &7kills!" to {_p2}
    if {_top3} is not "":
        set {_p3} to {_top3} parsed as offline player
        if {_p3} is online:
            pdInit({_p3})
            add {_bonus3} to {pd.%{_top3}%.reputation}
            if {_xp} > 0:
                set {_curlevel} to {_p3}'s level
                set {_p3}'s level to {_curlevel} + {_xp}
            if {_bucksbonus3} > 0:
                make console execute command "bucks give % {_p3}% %{_bucksbonus3}%"
            pdUpdateStars({_p3})
            pdSyncMeta({_p3})
            broadcast "{@event_prefix}&7&l3rd Place: &e%{_p3}% &7with &c%{_top3kills}% &7kills! &6+%{_bonus3}% rep"
            send "{@event_prefix}&7&l🥉 3rd Place! &7+&e%{_bonus3}% &7rep for &c%{_top3kills}% &7kills!" to {_p3}

# ============================================================
# BUG 2 FIX — EVENT HISTORY COMMAND
# /eventhistory [page] — shows last 10 events, with winners and top killer
# ============================================================

command /eventhistory [<integer>]:
    aliases: /evhistory, /ehistory
    description: View recent event history, winners, and top killers
    trigger:
        if {pd.history.count} is not set:
            send "{@prefix}&7No events have been run yet."
            stop
        set {_total} to {pd.history.count}
        set {_page} to 1
        if arg-1 is set:
            set {_page} to arg-1
        set {_perpage} to 5
        set {_maxpage} to ceil({_total} / {_perpage})
        if {_page} > {_maxpage}:
            set {_page} to {_maxpage}
        if {_page} < 1:
            set {_page} to 1
        set {_start} to {_total} - ({_page} - 1) * {_perpage}
        set {_end} to {_start} - {_perpage} + 1
        if {_end} < 1:
            set {_end} to 1
        send "" to player
        send "&8&m                                                    " to player
        send "  &6&l✦ Event History &8(Page %{_page}%/%{_maxpage}%)" to player
        send "" to player
        set {_i} to {_start}
        loop {_perpage} times:
            if {_i} < 1:
                stop
            set {_htitle} to {pd.history.%{_i}%.title}
            if {_htitle} is not set:
                set {_htitle} to "Unknown Event"
            set {_htype} to {pd.history.%{_i}%.type}
            if {_htype} is not set:
                set {_htype} to "?"
            set {_hdate} to {pd.history.%{_i}%.date}
            if {_hdate} is not set:
                set {_hdate} to "Unknown"
            set {_hpart} to {pd.history.%{_i}%.participants}
            if {_hpart} is not set:
                set {_hpart} to 0
            set {_htopkuuid} to {pd.history.%{_i}%.top_killer}
            set {_htopk} to {pd.history.%{_i}%.top_kills}
            set {_topkname} to "N/A"
            if {_htopkuuid} is set:
                if {_htopkuuid} is not "":
                    set {_topkop} to {_htopkuuid} parsed as offline player
                    set {_topkname} to "%{_topkop}%"
            send "  &8#%{_i}% &e%{_htitle}% &8[&7%{_htype}%&8]" to player
            send "       &7Date: &f%{_hdate}% &8| &7Players: &e%{_hpart}%" to player
            send "       &7Top Killer: &c%{_topkname}% &8(&c%{_htopk}% kills&8)" to player
            send "" to player
            subtract 1 from {_i}
        if {_page} < {_maxpage}:
            send "  &7Use &e/eventhistory %({_page} + 1)% &7for older events." to player
        send "&8&m                                                    " to player
        send "" to player

command /clearevents:
    permission: klawcraft.admin
    description: Clear all event history records
    trigger:
        if {pd.history.count} is not set:
            send "{@prefix}&7No history to clear."
            stop
        set {_total} to {pd.history.count}
        loop {_total} times:
            delete {pd.history.%loop-number%.type}
            delete {pd.history.%loop-number%.title}
            delete {pd.history.%loop-number%.date}
            delete {pd.history.%loop-number%.participants}
            delete {pd.history.%loop-number%.top_killer}
            delete {pd.history.%loop-number%.top_kills}
            delete {pd.history.%loop-number%.winners::*}
        delete {pd.history.count}
        send "{@prefix}&aEvent history cleared (%{_total}% records deleted)."

# ============================================================
# EVENT STATUS COMMAND
# BUG 5 FIX: Shows event title at top of /eventstatus
# BUG 3 FIX: Always shows kill leaderboard during active event
# ============================================================

command /eventstatus:
    aliases: /pdstatus, /event
    description: Check current event status
    trigger:
        if {pd.active} is not true:
            send "{@prefix}&7No event is currently running."
            stop
        set {_typename} to pdTypeName({pd.active.type})
        set {_phase} to {pd.active.phase}
        set {_count} to size of {pd.active.players::*}
        set {_displaytitle} to {_typename}
        if {pd.active.title} is set:
            set {_displaytitle} to {pd.active.title}
        send "" to player
        send "&8&m                                                    " to player
        # BUG 5 FIX: Title shown prominently at top
        # EVENT INFO PANEL FIX: Clear separation of title, type, region
        send "  &6&l✦ Event: &e%{_displaytitle}%" to player
        send "  &7Mode: &e%{_typename}% &8| &7Phase: &e%{_phase}%" to player
        send "" to player
        send "  &7Players: &e%{_count}%" to player
        send "  &7Injury: &e%{pd.active.injury}% &8| &7PvP: &e%{pd.active.pvp}%" to player
        # REGION FIX: Default to "New York City" if not set
        set {_regiondisplay} to {pd.active.region}
        if {_regiondisplay} is not set:
            set {_regiondisplay} to "New York City"
        send "  &7Region: &e%{_regiondisplay}%" to player
        set {_durmins} to floor({pd.active.duration} / 60)
        if {_durmins} < 1:
            send "  &7Duration: &e%{pd.active.duration}%s" to player
        else:
            send "  &7Duration: &e%{_durmins}% min" to player
        if {pd.active.type} is "factionwar":
            set {_t1a} to 0
            set {_t2a} to 0
            loop all players:
                if {pd.active.team1::*} contains loop-player's uuid:
                    if {pd.active.dead::*} does not contain loop-player's uuid:
                        add 1 to {_t1a}
                if {pd.active.team2::*} contains loop-player's uuid:
                    if {pd.active.dead::*} does not contain loop-player's uuid:
                        add 1 to {_t2a}
            send "  &9Team 1 (Heroes): &a%{_t1a}% alive" to player
            send "  &cTeam 2 (Villains): &a%{_t2a}% alive" to player
        if {pd.active.vip} is set:
            set {_vipchar} to {char.%{pd.active.vip}%.firstname}
            if {_vipchar} is not set:
                set {_vipop2} to {pd.active.vip} parsed as offline player
                set {_vipchar} to "%{_vipop2}%"
            send "  &6&l★ VIP: &e%{_vipchar}%" to player
            send "  &cAttackers: &e%size of {pd.active.attackers::*}% &8| &aDefenders: &e%size of {pd.active.defenders::*}%" to player
        set {_bucksmsg} to ""
        if {pd.active.bucks_reward} > 0:
            set {_bucksmsg} to " &8| &7Bucks: &e%{pd.active.bucks_reward}%"
        send "  &7Rewards: &e%{pd.active.rep_reward}% &7rep, &e%{pd.active.xp_reward}% &7XP%{_bucksmsg}%" to player
        # Show respawn mode status
        if {pd.active.respawn_mode} is true:
            send "  &7Respawn Mode: &aON &7(normal respawn)" to player
        else:
            send "  &7Respawn Mode: &cOFF &7(spectator on death)" to player
        # Show injury status
        if {pd.active.injury} is true:
            send "  &7Injury: &cENABLED" to player
        else:
            send "  &7Injury: &aDISABLED" to player
        # Show reward mode
        set {_rmode} to {pd.active.reward_mode}
        if {_rmode} is not set:
            set {_rmode} to 1
        set {_rmname} to "SURVIVAL"
        if {_rmode} is 0:
            set {_rmname} to "MANUAL"
        else if {_rmode} is 2:
            set {_rmname} to "KILLS"
        else if {_rmode} is 3:
            set {_rmname} to "TEAM KILLS"
        else if {_rmode} is 4:
            set {_rmname} to "LAST MAN"
        send "  &7Win Mode: &e%{_rmname}%" to player
        # LORE DISPLAY: At bottom, above leaderboard, with spacing
        if {pd.active.lore_text} is set:
            send "" to player
            send "  &d&l✦ Lore/Story:" to player
            send "  &d%{pd.active.lore_text}%" to player
        # BUG 3 FIX: Always show top killers in status — uses participants list
        if {_phase} is "active":
            send "" to player
            send "  &c&l⚔ Kill Leaderboard:" to player
            # Use participants list — includes ALL players who joined, never removed
            set {_allp::*} to {pd.active.participants::*}
            set {_shown} to 0
            set {_top1u} to ""
            set {_top1k} to 0
            set {_top2u} to ""
            set {_top2k} to 0
            set {_top3u} to ""
            set {_top3k} to 0
            loop {_allp::*}:
                set {_kv2} to {pd.active.kills.%loop-value%}
                if {_kv2} is not set:
                    set {_kv2} to 0
                if {_kv2} > {_top1k}:
                    set {_top3u} to {_top2u}
                    set {_top3k} to {_top2k}
                    set {_top2u} to {_top1u}
                    set {_top2k} to {_top1k}
                    set {_top1u} to loop-value
                    set {_top1k} to {_kv2}
                else if {_kv2} > {_top2k}:
                    set {_top3u} to {_top2u}
                    set {_top3k} to {_top2k}
                    set {_top2u} to loop-value
                    set {_top2k} to {_kv2}
                else if {_kv2} > {_top3k}:
                    set {_top3u} to loop-value
                    set {_top3k} to {_kv2}
            if {_top1u} is not "":
                set {_topop1} to {_top1u} parsed as offline player
                send "  &6🥇 &e%{_topop1}% &8— &c%{_top1k}% kills" to player
            if {_top2u} is not "":
                set {_topop2} to {_top2u} parsed as offline player
                send "  &7🥈 &e%{_topop2}% &8— &c%{_top2k}% kills" to player
            if {_top3u} is not "":
                set {_topop3} to {_top3u} parsed as offline player
                send "  &7🥉 &e%{_topop3}% &8— &c%{_top3k}% kills" to player
            if {_top1u} is "":
                send "  &8No kills recorded yet." to player
        send "" to player
        if {_phase} is "countdown":
            send "  &a/joinevent &7to join | &c/declineevent &7to decline" to player
        send "&8&m                                                    " to player
        send "" to player

