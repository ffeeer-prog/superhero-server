# ============================================================
# COUNTDOWN PHASE
# BUG 5 & 9 FIX: Title shown in broadcast; countdown timer works correctly
# ============================================================

function pdCountdown(type: text, ispd: boolean, countdown: number=60):
    # BUG 6 FIX: {_secs} must be set from the parameter, not a hardcoded default
    set {_secs} to {_countdown}
    if {_secs} is not set:
        set {_secs} to 25
    if {_secs} <= 0:
        set {_secs} to 5
    set {_typename} to pdTypeName({_type})
    # BUG 5 FIX: Use custom title if set, fallback to type name
    set {_displaytitle} to {_typename}
    if {pd.active.title} is set:
        set {_displaytitle} to {pd.active.title}
    # Broadcast initial warning
    broadcast "&8&m                                                    "
    broadcast ""
    if {_ispd} is true:
        broadcast "  &4&l⚠ PERMADEATH EVENT ⚠"
    else:
        broadcast "  &b&l✦ LORE EVENT ✦"
    broadcast ""
    # BUG 5 FIX: Show event title prominently
    broadcast "  &6&l%{_displaytitle}%"
    broadcast "  &7Type: &e%{_typename}%"
    if {_ispd} is true:
        broadcast "  &c&lDEATH WILL RESULT IN INJURY STATUS"
    else:
        if {pd.active.injury} is true:
            broadcast "  &e&lInjury mode is ENABLED for this event"
        else:
            broadcast "  &a&lNo injury risk — safe event"
    set {_durmins} to floor({pd.active.duration} / 60)
    if {_durmins} < 1:
        broadcast "  &7Duration: &e%{pd.active.duration}%s"
    else:
        broadcast "  &7Duration: &e%{_durmins}% Minutes"
    if {pd.active.lore_text} is set:
        broadcast ""
        broadcast "  &d&l\"%{pd.active.lore_text}%\""
    broadcast ""
    set {_bucksbroadcast} to ""
    if {pd.active.bucks_reward} > 0:
        set {_bucksbroadcast} to ", &e%{pd.active.bucks_reward}% &7Bucks"
    broadcast "  &7Rewards: &e%{pd.active.rep_reward}% &7rep, &e%{pd.active.xp_reward}% &7XP levels%{_bucksbroadcast}%"
    if {pd.active.vip} is set:
        set {_vipchar} to {char.%{pd.active.vip}%.firstname}
        if {_vipchar} is not set:
            set {_vipop} to {pd.active.vip} parsed as offline player
            set {_vipchar} to "%{_vipop}%"
        broadcast "  &6&l★ VIP: &e%{_vipchar}% &7must be protected!"
    broadcast ""
    broadcast "  <cmd:/joinevent>&a&l[ACCEPT]&r&7 Join the event</cmd>  <cmd:/declineevent>&c&l[DECLINE]&r&7 Stay out</cmd>"
    broadcast "  &7Or type &a/joinevent &7/ &c/declineevent"
    broadcast ""
    broadcast "&8&m                                                    "
    # BUG 5 & 9 FIX: Title shows event name correctly
    if {_ispd} is true:
        send title "&4&l%{_displaytitle}%" with subtitle "&c&lPermadeath Event — Join or Decline?" to all players for 5 seconds
    else:
        send title "&b&l%{_displaytitle}%" with subtitle "&7Lore Event — Join or Decline?" to all players for 5 seconds
    make console execute command "playsound minecraft:entity.ender_dragon.growl master @a ~ ~ ~ 0.3 1"
    wait 3 seconds
    # COUNTDOWN BOSSBAR: Create separate countdown bossbar using SkBee
    # CRITICAL: Delete any existing countdown bossbar first
    set {_existingcd} to boss bar from id "pd_countdown"
    if {_existingcd} is set:
        delete boss bar {_existingcd}
    set {_cdcolor} to red if {_ispd} is true else blue
    # Step-by-step creation for compatibility with different SkBee versions
    create boss bar with id "pd_countdown"
    set {_cdbar} to boss bar from id "pd_countdown"
    if {_cdbar} is not set:
        broadcast "&c[DEBUG] Failed to create countdown bossbar!"
    else:
        set boss bar title of {_cdbar} to "&e%{_displaytitle}% &7| &fStarting in..."
        set boss bar color of {_cdbar} to {_cdcolor}
        set boss bar style of {_cdbar} to notched_20
        set boss bar progress of {_cdbar} to 100
        add all players to {_cdbar}
    # TAB bossbar placeholder variables
    set {pd_tab_countdown_active} to "true"
    set {pd_tab_bossbar_title} to "&e%{_displaytitle}% &7| &fStarting in..."
    set {pd_tab_bossbar_progress} to "100"
    # BUG 6 FIX: Loop actually counts down properly using the passed-in value
    set {_i} to 0
    loop {_secs} times:
        if {pd.active} is not true:
            # Clean up countdown bossbar if event cancelled
            if {_cdbar} is set:
                delete boss bar {_cdbar}
            stop
        add 1 to {_i}
        set {_remaining} to {_secs} - {_i} + 1
        # Update countdown bossbar progress and title
        set {_pct} to ({_remaining} / {_secs}) * 100
        set boss bar progress of {_cdbar} to {_pct}
        set boss bar title of {_cdbar} to "&e%{_displaytitle}% &7| &fStarting in &e%{_remaining}%s"
        # Update TAB placeholders
        set {pd_tab_bossbar_title} to "&e%{_displaytitle}% &7| &fStarting in &e%{_remaining}%s"
        set {pd_tab_bossbar_progress} to "%{_pct}%"
        if {_remaining} <= 10:
            if {_ispd} is true:
                send title "&4&l%{_remaining}%" with subtitle "&c&lDeath = Injury Status" to all players
            else:
                send title "&b&l%{_remaining}%" with subtitle "&7Lore event starting..." to all players
            make console execute command "playsound minecraft:block.note_block.hat master @a ~ ~ ~ 0.5 1"
        wait 1 second
    # Remove countdown bossbar before starting main event
    if {_cdbar} is set:
        delete boss bar {_cdbar}
    # Switch TAB placeholders from countdown to active
    set {pd_tab_countdown_active} to "false"
    set {pd_tab_event_active} to "true"
    if {pd.active} is not true:
        stop
    # MIN PLAYERS CHECK: Cancel event if not enough participants
    if {pd.minplayers.enabled} is true:
        set {_partcount} to size of {pd.active.players::*}
        if {_partcount} < 2:
            broadcast "{@event_prefix}&c&lEVENT CANCELLED! &7Not enough players (&e%{_partcount}% &7/ &e2&7 minimum)"
            pdEndEvent()
            stop
    # AUTO TEAM ASSIGNMENT: Assign unassigned players to teams before event starts
    if {pd.active.type} is "factionwar":
        pdAutoAssignTeams()
    # Auto-decline non-responders
    loop all players:
        set {_auuid} to loop-player's uuid
        if {pd.active.players::*} does not contain {_auuid}:
            if {pd.active.declined::*} does not contain {_auuid}:
                add {_auuid} to {pd.active.declined::*}
                set game mode of loop-player to spectator
                give loop-player 1 cookie named "&6&lGood Sport Cookie" with lore "&7Thanks for waiting!"
                send "{@prefix}&7You were auto-declined from the event (no response). Spectator until event ends." to loop-player
    set {pd.active.phase} to "active"
    set {pd.active.start_time} to now
    if {_ispd} is true:
        broadcast "{@event_prefix}&4&lTHE EVENT HAS BEGUN! &7Fight for survival!"
        send title "&4&l⚔ %{_displaytitle}% ⚔" with subtitle "&cPermadeath Event Active" to all players for 3 seconds
    else:
        broadcast "{@lore_prefix}&b&lThe Lore Event has begun!"
        send title "&b&l✦ %{_displaytitle}% ✦" with subtitle "&7Lore Event Active" to all players for 3 seconds
    make console execute command "playsound minecraft:entity.ender_dragon.growl master @a ~ ~ ~ 0.5 1"
    # Teleport teams to their spawn points if set
    if {pd.active.team1_spawn} is set:
        loop all players:
            if {pd.active.team1::*} contains loop-player's uuid:
                teleport loop-player to {pd.active.team1_spawn}
    if {pd.active.team2_spawn} is set:
        loop all players:
            if {pd.active.team2::*} contains loop-player's uuid:
                teleport loop-player to {pd.active.team2_spawn}
    # Start the bossbar timer
    pdStartBossbar({_ispd}, {_displaytitle})

# ============================================================
# BUG 4 FIX — BOSSBAR: Completely rewritten using SkBee
# Uses SkBee boss bar expressions for clean, error-free operation
# BUG 5 FIX: Bossbar shows the event title from {pd.active.title}
# BUG 6 FIX: Timer counts down correctly using {pd.active.duration}
# ============================================================

function pdStartBossbar(ispd: boolean, displaytitle: text):
    # CRITICAL: Delete any existing bossbar with this ID first to prevent conflicts
    set {_existing} to boss bar from id "pd_event"
    if {_existing} is set:
        delete boss bar {_existing}
    # Create the bossbar fresh using SkBee — step-by-step for compatibility
    # SkBee colors: blue, red, green, yellow, purple, pink, white
    set {_color} to red if {_ispd} is true else blue
    create boss bar with id "pd_event"
    set {_bar} to boss bar from id "pd_event"
    if {_bar} is not set:
        broadcast "&c[DEBUG] Failed to create bossbar! Trying TAB fallback..."
        # TAB FALLBACK: If SkBee fails, use TAB bossbar via console command
        # Requires TAB plugin + PlaceholderAPI + skript-placeholders
        set {_tabcmd} to "tab bossbar add pd_event &e%{_displaytitle}% &7| &e0:00 %{_color}% PROGRESS 100"
        make console execute command {_tabcmd}
        set {pd.active.bossbar} to "pd_event_tab"
        # Skip SkBee loop, use action bar as timer fallback
        set {_dur} to {pd.active.duration}
        set {_start} to now
        while {pd.active} is true and {pd.active.phase} is "active":
            set {_elapsed} to difference between {_start} and now in seconds
            set {_remaining} to {_dur} - {_elapsed}
            if {_remaining} <= 0:
                stop
            set {_mins} to floor({_remaining} / 60)
            set {_secs} to floor({_remaining} mod 60)
            set {_secstr} to "%{_secs}%"
            if {_secs} < 10:
                set {_secstr} to "0%{_secs}%"
            if {_ispd} is true:
                send action bar "&4&l⚔ %{_displaytitle}% &8| &e%{_mins}%:%{_secstr}% remaining" to all players where [{pd.active.players::*} contains input's uuid]
            else:
                send action bar "&b&l✦ %{_displaytitle}% &8| &e%{_mins}%:%{_secstr}% remaining" to all players where [{pd.active.players::*} contains input's uuid]
            wait 1 second
        # Cleanup TAB bossbar
        make console execute command "tab bossbar remove pd_event"
        delete {pd.active.bossbar}
        stop
    set {pd.active.bossbar} to "pd_event"
    # Set bossbar properties step-by-step
    set boss bar title of {_bar} to "%{_displaytitle}%"
    set boss bar color of {_bar} to {_color}
    set boss bar style of {_bar} to notched_10
    set boss bar progress of {_bar} to 100
    # Add ALL online participants to the bossbar
    set {_added} to 0
    loop {pd.active.participants::*}:
        set {_uuid} to loop-value
        set {_p} to {_uuid} parsed as offline player
        if {_p} is online:
            add {_p} to {_bar}
            add 1 to {_added}
    # Also add all currently joined players
    loop {pd.active.players::*}:
        set {_uuid} to loop-value
        set {_p} to {_uuid} parsed as offline player
        if {_p} is online:
            if {_p} is not in {_bar}:
                add {_p} to {_bar}
    # Update loop - runs while event is active
    set {_dur} to {pd.active.duration}
    set {_start} to now
    while {pd.active} is true and {pd.active.phase} is "active":
        set {_elapsed} to difference between {_start} and now in seconds
        set {_remaining} to {_dur} - {_elapsed}
        set {_pct} to ({_remaining} / {_dur}) * 100
        if {_pct} < 0:
            set {_pct} to 0
        if {_pct} > 100:
            set {_pct} to 100
        # Calculate time display
        set {_mins} to floor({_remaining} / 60)
        set {_secs} to floor({_remaining} mod 60)
        set {_secstr} to "%{_secs}%"
        if {_secs} < 10:
            set {_secstr} to "0%{_secs}%"
        # Update bossbar using SkBee
        set boss bar progress of {_bar} to {_pct}
        set boss bar title of {_bar} to "%{_displaytitle}% &7| &e%{_mins}%:%{_secstr}%"
        # Update TAB placeholders
        set {pd_tab_bossbar_title} to "%{_displaytitle}% &7| &e%{_mins}%:%{_secstr}%"
        set {pd_tab_bossbar_progress} to "%{_pct}%"
        # Action bar reminder every 60 seconds
        if {_elapsed} > 0 and {_elapsed} mod 60 is 0:
            if {_ispd} is true:
                send action bar "&4&l⚔ %{_displaytitle}% &8| &e%{_mins}%:%{_secstr}% remaining" to all players where [{pd.active.players::*} contains input's uuid]
            else:
                send action bar "&b&l✦ %{_displaytitle}% &8| &e%{_mins}%:%{_secstr}% remaining" to all players where [{pd.active.players::*} contains input's uuid]
        wait 1 second
    # Cleanup when loop ends
    if {_bar} is set:
        delete boss bar {_bar}
    delete {pd.active.bossbar}
    # Clean up TAB placeholders
    set {pd_tab_countdown_active} to "false"
    set {pd_tab_event_active} to "false"
    set {pd_tab_bossbar_title} to ""
    set {pd_tab_bossbar_progress} to "0"
    # Timer expired — end the event naturally
    if {pd.active} is true:
        if {pd.active.phase} is "active":
            pdEndEvent()

function pdTypeName(type: text) :: text:
    if {_type} is "roam":
        return "PD Roam"
    else if {_type} is "elimination":
        return "Elimination"
    else if {_type} is "factionwar":
        return "Faction War"
    else if {_type} is "hunted":
        return "Hunted"
    else if {_type} is "escort":
        return "Escort"
    else if {_type} is "rescue":
        return "Rescue"
    else if {_type} is "protect":
        return "Protect the VIP"
    else if {_type} is "controlzone":
        return "Control Zone"
    else if {_type} is "blackout":
        return "Blackout"
    else if {_type} is "supplydrop":
        return "Supply Drop"
    else if {_type} is "survivors":
        return "Survivors"
    else if {_type} is "lore":
        return "Lore Event"
    return {_type}

# ============================================================
# PLAYER JOIN/DECLINE/LEAVE
# ============================================================

command /joinevent:
    aliases: /joinpd, /join
    description: Join the active Permadeath or Lore event
    trigger:
        if {pd.active} is not true:
            send "{@prefix}&cNo event is currently running."
            stop
        set {_uuid} to player's uuid
        if {pd.active.phase} is "active":
            # BUG 8 FIX: If player died during the event, block them
            if {pd.active.dead::*} contains {_uuid}:
                set game mode of player to spectator
                send "{@prefix}&cYou died during this event. You cannot re-enter."
                stop
            if {pd.active.declined::*} contains {_uuid}:
                set game mode of player to spectator
                send "{@prefix}&7You are already waiting for the event to end."
                stop
            add {_uuid} to {pd.active.declined::*}
            set game mode of player to spectator
            give player 1 cookie named "&6&lGood Sport Cookie" with lore "&7Thanks for waiting!"
            send "{@prefix}&7The event is already in progress! You've been put in &eSpectator&7 mode."
            stop
        if {pd.active.phase} is "ending":
            send "{@prefix}&cThe event is ending."
            stop
        pdInit(player)
        if {pd.active.players::*} contains {_uuid}:
            send "{@prefix}&7You are already in the event."
            stop
        # BUG 7 FIX: Always block injured/dead players from joining
        if {pd.%{_uuid}%.status} is "injured":
            send "{@prefix}&cYou are &4&lINJURED&c! You cannot join events."
            send "{@prefix}&7Events locked: &c%{pd.%{_uuid}%.injury_remaining}% &7| Use &e/hospital &7to heal"
            stop
        if {pd.%{_uuid}%.status} is "dead":
            send "{@prefix}&cYou are &4&lDEAD&c! You cannot join events."
            send "{@prefix}&7Use &e/resurrect &7(&a20k Bucks&7) or &e/hospital &7(&a10k Bucks&7) to revive"
            stop
        if {char.%{_uuid}%.created} is not true:
            send "{@prefix}&cCreate a character first!"
            stop
        if {char.%{_uuid}%.usemcname} is set:
            set {pd.eventchatname.%{_uuid}%} to true
        delete {char.%{_uuid}%.usemcname}
        updateCharacterDisplay(player)
        syncPlayerMeta(player)
        add {_uuid} to {pd.active.players::*}
        # PARTICIPATION TRACKING: Add to participants list (never removed until event end)
        add {_uuid} to {pd.active.participants::*}
        # Initialize kill counter for this player
        set {pd.active.kills.%{_uuid}%} to 0
        add 1 to {pd.%{_uuid}%.events_played}
        # BOSSBAR FIX: Add player to existing bossbar if event is active
        if {pd.active.bossbar} is set:
            set {_bar} to boss bar from id "pd_event"
            if {_bar} is set:
                if player is not in {_bar}:
                    add player to {_bar}
        set {_typename} to pdTypeName({pd.active.type})
        send "{@prefix}&a&l✓ Joined Event! &7%{_typename}%" to player
        make console execute command "playsound minecraft:entity.player.levelup master %player% ~ ~ ~ 0.5 1.2"
        set {_etype} to {pd.active.type}
        if {_etype} is "factionwar":
            send "  &9&l⚔ FACTION WAR ⚔" to player
            send "  &7Choose your side! Use &e/jointeam 1 &7(Heroes) or &e/jointeam 2 &7(Villains)" to player
        else if {_etype} is "elimination":
            send "  &c&l☠ ELIMINATION ☠" to player
            send "  &7Last one standing wins! If you die, you're out." to player
        else if {_etype} is "roam" or {_etype} is "survivors":
            send "  &4&l⚔ %{_typename}% ⚔" to player
            send "  &7Free roam PvP! Fight anyone, survive until the timer runs out." to player
        broadcast "{@prefix}&e%player% &7joined the event! &8(%size of {pd.active.players::*}% players)"

command /declineevent:
    aliases: /declinepd, /decline
    description: Decline the current event
    trigger:
        if {pd.active} is not true:
            send "{@prefix}&cNo event is currently running."
            stop
        set {_uuid} to player's uuid
        if {pd.active.phase} is "active":
            if {pd.active.declined::*} contains {_uuid}:
                send "{@prefix}&7You are already waiting for the event to end."
                stop
            if {pd.active.players::*} contains {_uuid}:
                remove {_uuid} from {pd.active.players::*}
            add {_uuid} to {pd.active.declined::*}
            set game mode of player to spectator
            give player 1 cookie named "&6&lGood Sport Cookie" with lore "&7Thanks for waiting!"
            send "{@prefix}&7You've been put in &eSpectator&7 mode. Please wait until the event is over."
            stop
        if {pd.active.phase} is "countdown":
            if {pd.active.players::*} contains {_uuid}:
                remove {_uuid} from {pd.active.players::*}
                send "{@prefix}&7You left the event queue."
            else:
                send "{@prefix}&7You declined the event."
            stop
        send "{@prefix}&7You declined the event."

command /leaveevent:
    description: Leave the active event (penalty: -10 XP levels, -5 reputation if accepted)
    trigger:
        if {pd.active} is not true:
            send "{@prefix}&cNo event is currently running."
            stop
        set {_uuid} to player's uuid
        if {pd.active.players::*} does not contain {_uuid}:
            send "{@prefix}&cYou are not in the event."
            stop
        if {leave.confirm.%{_uuid}%} is not true:
            set {leave.confirm.%{_uuid}%} to true
            send "" to player
            send "&8&m                                                    " to player
            send "  &c&l⚠ LEAVE EVENT? ⚠" to player
            send "" to player
            send "  &7Leaving will cost:" to player
            send "  &c-10 Minecraft XP Levels" to player
            send "  &c-5 Reputation" to player
            send "" to player
            send "  &a&l▶ Type /leaveevent again &ato confirm" to player
            send "  &7Or wait 10 seconds to cancel" to player
            send "&8&m                                                    " to player
            send "" to player
            wait 10 seconds
            delete {leave.confirm.%{_uuid}%}
            stop
        delete {leave.confirm.%{_uuid}%}
        remove {_uuid} from {pd.active.players::*}
        set {_lvl} to player's level
        if {_lvl} >= {@leave_xp_penalty}:
            set player's level to {_lvl} - {@leave_xp_penalty}
        else:
            set player's level to 0
            set player's xp progress to 0
        pdInit(player)
        remove {@leave_rep_penalty} from {pd.%{_uuid}%.reputation}
        if {pd.%{_uuid}%.reputation} < 0:
            set {pd.%{_uuid}%.reputation} to 0
        pdUpdateStars(player)
        pdSyncMeta(player)
        send "{@event_prefix}&cYou left the event. &7Penalties applied: &c-{@leave_xp_penalty} Levels&7, &c-{@leave_rep_penalty} Rep"

# ============================================================
# PLAYER — JOIN TEAM COMMAND (for team-based events)
# ============================================================

command /jointeam <integer>:
    description: Join team 1 or 2 for team-based events (faction war, controlzone, etc.)
    trigger:
        if {pd.active} is not true:
            send "{@prefix}&cNo event is currently running."
            stop
        set {_type} to {pd.active.type}
        # Only allow for team-based events
        if {_type} is not "factionwar" and {_type} is not "controlzone" and {_type} is not "elimination":
            send "{@prefix}&cThis event type does not have teams."
            stop
        if {pd.active.phase} is not "countdown":
            if {pd.active.phase} is "active":
                send "{@prefix}&cThe event has already started! You cannot join a team now."
                stop
            send "{@prefix}&cYou can only pick a team during the countdown."
            stop
        set {_uuid} to player's uuid
        if {pd.active.players::*} does not contain {_uuid}:
            send "{@prefix}&cYou must join the event first with &a/joinevent&c!"
            stop
        # For factionwar — show affiliation info but allow free team choice
        if {_type} is "factionwar":
            set {_myaffil} to ""
            # FIX: Use affiliation.* permissions (consistent with /pdfactions)
            if player has permission "affiliation.hero":
                set {_myaffil} to "hero"
            else if player has permission "affiliation.villain":
                set {_myaffil} to "villain"
            else if player has permission "affiliation.mercenary":
                set {_myaffil} to "mercenary"
            else if player has permission "affiliation.bountyhunter":
                set {_myaffil} to "bountyhunter"
            # Fallback to house variable if no permission found
            if {_myaffil} is "":
                set {_myhouse} to lowercase {char.%{_uuid}%.house}
                if {_myhouse} is "hero":
                    set {_myaffil} to "hero"
                else if {_myhouse} is "villain":
                    set {_myaffil} to "villain"
                else if {_myhouse} is "mercenary":
                    set {_myaffil} to "mercenary"
                else if {_myhouse} is "bountyhunter":
                    set {_myaffil} to "bountyhunter"
            # Show affiliation info but allow free choice
            if {_myaffil} is "hero":
                send "{@prefix}&7You are affiliated with &9&lHeroes&7 — joining &9Team 1&7." to player
            else if {_myaffil} is "villain":
                send "{@prefix}&7You are affiliated with &c&lVillains&7 — joining &cTeam 2&7." to player
            else if {_myaffil} is "mercenary":
                send "{@prefix}&7You are a &8&lMercenary&7 — choose any team." to player
            else if {_myaffil} is "bountyhunter":
                send "{@prefix}&7You are a &6&lBounty Hunter&7 — choose any team." to player
        # Assign to team and give banner
        if arg-1 is 1:
            remove {_uuid} from {pd.active.team2::*}
            add {_uuid} to {pd.active.team1::*}
            make console execute command "give %player% minecraft:blue_banner{display:{Name:'\"\\u00a79\\u00a7lHero Banner\"',Lore:['\"\\u00a77Team 1 - Heroes\"','\"\\u00a77Fight for justice!\"','\"\\u00a78Event Item - Returns after event\"']},pd_banner:1b,Unbreakable:1b,HideFlags:255} 1"
            send "{@event_prefix}&7You joined &9&lTeam 1&7!" to player
        else if arg-1 is 2:
            remove {_uuid} from {pd.active.team1::*}
            add {_uuid} to {pd.active.team2::*}
            make console execute command "give %player% minecraft:red_banner{display:{Name:'\"\\u00a7c\\u00a7lVillain Banner\"',Lore:['\"\\u00a77Team 2 - Villains\"','\"\\u00a77Embrace the darkness!\"','\"\\u00a78Event Item - Returns after event\"']},pd_banner:1b,Unbreakable:1b,HideFlags:255} 1"
            send "{@event_prefix}&7You joined &c&lTeam 2&7!" to player
        else:
            send "{@prefix}&cUse &e/jointeam 1 &7or &e/jointeam 2"

# ============================================================
# DAMAGE LISTENER — Track last attacker for reliable kill tracking
# CRITICAL: Hardcore Revival mod breaks the 'attacker' variable in death event
# We track damage events to always know who last hit a player
# ============================================================

on damage of player:
    if {pd.active} is true:
        if {pd.active.phase} is "active":
            if attacker is a player:
                set {pd.lastattacker.%victim's uuid%} to attacker's uuid

# ============================================================
# DEATH HANDLER
# BUG 3 FIX: Kill counter always tracked regardless of event type
# BUG 10 FIX: Announces who died, kill count, and players remaining
#             For faction/escort: announces team counts
# ============================================================

on death of player:
    if {pd.active} is true:
        if {pd.active.phase} is "active":
            set {_uuid} to victim's uuid
            if {pd.active.players::*} contains {_uuid}:
                if {pd.deathguard.%{_uuid}%} is true:
                    stop
                if victim's health > 0:
                    stop
                set {pd.deathguard.%{_uuid}%} to true
                # BUG 3 FIX: Always track kills, regardless of event type
                # CRITICAL FIX: Use lastattacker instead of attacker (Hardcore Revival compatibility)
                set {_killeruuid} to {pd.lastattacker.%{_uuid}%}
                set {_killerchar} to "Unknown"
                if {_killeruuid} is set:
                    if {pd.active.players::*} contains {_killeruuid}:
                        add 1 to {pd.active.kills.%{_killeruuid}%}
                        add 1 to {pd.%{_killeruuid}%.event_kills}
                        set {_killerp} to {_killeruuid} parsed as offline player
                        set {_killerchar} to {char.%{_killeruuid}%.firstname}
                        if {_killerchar} is not set:
                            set {_killerchar} to {_killerp}'s name
                        set {_kc} to {pd.active.kills.%{_killeruuid}%}
                        if {_killerp} is online:
                            send "{@event_prefix}&6&l+1 Kill &7[Total this event: &c%{_kc}%&7]" to {_killerp} parsed as player
                # Clear last attacker after processing
                delete {pd.lastattacker.%{_uuid}%}
                set {_victimchar} to {char.%{_uuid}%.firstname}
                if {_victimchar} is not set:
                    set {_victimchar} to victim's name
                # Add to dead list
                add {_uuid} to {pd.active.dead::*}
                set {_victimplayer} to victim
                wait 1 tick
                delete {pd.deathguard.%{_uuid}%}
                # RESPAWN MODE CHECK: If respawn_mode is true, player respawns normally
                if {pd.active.respawn_mode} is true:
                    # Player will respawn naturally, no spectator or injury
                    send "{@event_prefix}&7You died but will respawn normally. (Respawn Mode: ON)" to {_victimplayer}
                else:
                    # Normal permadeath behavior - go to spectator and apply injury if enabled
                    if {_victimplayer} is online:
                        set game mode of {_victimplayer} to spectator
                    # INJURY TOGGLE FIX: Only apply injury if injury is enabled
                    if {pd.active.injury} is true:
                        pdApplyInjury({_victimplayer})
                    else:
                        send "{@event_prefix}&7You died in the event, but injury is disabled." to {_victimplayer}
                # BUG 10 FIX: Announce death with appropriate context per event type
                set {_etype} to {pd.active.type}
                set {_alive} to size of {pd.active.players::*} - size of {pd.active.dead::*}
                if {_alive} < 0:
                    set {_alive} to 0
                if {_etype} is "factionwar":
                    # Count alive players per team
                    set {_t1alive} to 0
                    set {_t2alive} to 0
                    loop all players:
                        if {pd.active.team1::*} contains loop-player's uuid:
                            if {pd.active.dead::*} does not contain loop-player's uuid:
                                add 1 to {_t1alive}
                        if {pd.active.team2::*} contains loop-player's uuid:
                            if {pd.active.dead::*} does not contain loop-player's uuid:
                                add 1 to {_t2alive}
                    broadcast "{@event_prefix}&c%{_victimchar}% &7was eliminated by &c%{_killerchar}%&7! &8| &9Heroes: &a%{_t1alive}% &8| &cVillains: &a%{_t2alive}%"
                else if {_etype} is "escort" or {_etype} is "rescue" or {_etype} is "protect":
                    set {_atkAlive} to 0
                    set {_defAlive} to 0
                    loop all players:
                        if {pd.active.attackers::*} contains loop-player's uuid:
                            if {pd.active.dead::*} does not contain loop-player's uuid:
                                add 1 to {_atkAlive}
                        if {pd.active.defenders::*} contains loop-player's uuid:
                            if {pd.active.dead::*} does not contain loop-player's uuid:
                                add 1 to {_defAlive}
                    broadcast "{@event_prefix}&c%{_victimchar}% &7was eliminated by &c%{_killerchar}%&7! &8| &cAttackers: &a%{_atkAlive}% &8| &aDefenders: &a%{_defAlive}%"
                else if {_etype} is "elimination" or {_etype} is "survivors":
                    broadcast "{@event_prefix}&c%{_victimchar}% &7was eliminated by &c%{_killerchar}%&7! &8| &e%{_alive}% player(s) remaining"
                else:
                    broadcast "{@event_prefix}&c%{_victimchar}% &7was eliminated! &8| &e%{_alive}% alive"
                # Elimination type — remove from active player list
                if {_etype} is "elimination":
                    remove {_uuid} from {pd.active.players::*}
                    send "{@event_prefix}&c&lELIMINATED! &7You are out of the event." to {_victimplayer}
                    if size of {pd.active.players::*} is 1:
                        set {_winner} to first element of {pd.active.players::*}
                        set {_wop} to {_winner} parsed as offline player
                        broadcast "{@event_prefix}&6&l%{_wop}% &7wins the Elimination Event!"
                        pdEndEvent()
                # VIP death check
                if {pd.active.vip} is set:
                    if {_uuid} is {pd.active.vip}:
                        set {_vipname} to {char.%{_uuid}%.firstname}
                        if {_vipname} is not set:
                            set {_vipname} to {_victimplayer}'s name
                        broadcast "{@event_prefix}&c&lTHE VIP HAS FALLEN! &c&l%{_vipname}% &c&lwas killed!"
                        broadcast "{@event_prefix}&c&lATTACKERS WIN! &7The target has been eliminated."
                        pdRewardTeam("attackers")
                        pdEndEvent()

# ============================================================
# END EVENT
# ============================================================

command /endevent:
    permission: klawcraft.admin
    description: End the current event manually
    trigger:
        if {pd.active} is not true:
            send "{@prefix}&cNo event is currently running."
            stop
        pdEndEvent()

function pdEndEvent():
    if {pd.active} is not true:
        stop
    set {pd.active.phase} to "ending"
    set {_type} to {pd.active.type}
    set {_typename} to pdTypeName({_type})
    set {_displaytitle} to {_typename}
    if {pd.active.title} is set:
        set {_displaytitle} to {pd.active.title}
    # BUG 2 FIX: Save event to history before clearing data
    if {pd.history.count} is not set:
        set {pd.history.count} to 0
    add 1 to {pd.history.count}
    set {_hid} to {pd.history.count}
    set {pd.history.%{_hid}%.type} to {_type}
    set {pd.history.%{_hid}%.title} to {_displaytitle}
    set {pd.history.%{_hid}%.date} to "%now%"
    set {pd.history.%{_hid}%.participants} to size of {pd.active.participants::*}
    # Find top killer for history
    set {_tophist_kills} to 0
    set {_tophist_uuid} to ""
    loop all players:
        set {_ku} to loop-player's uuid
        set {_kval} to {pd.active.kills.%{_ku}%}
        if {_kval} is set:
            if {_kval} > {_tophist_kills}:
                set {_tophist_kills} to {_kval}
                set {_tophist_uuid} to {_ku}
    set {pd.history.%{_hid}%.top_killer} to {_tophist_uuid}
    set {pd.history.%{_hid}%.top_kills} to {_tophist_kills}
    # VIP survived (defenders win)
    if {pd.active.vip} is set:
        set {_vipuuid} to {pd.active.vip}
        if {pd.active.dead::*} does not contain {_vipuuid}:
            set {_vipchar} to {char.%{_vipuuid}%.firstname}
            if {_vipchar} is not set:
                set {_vipop} to {_vipuuid} parsed as offline player
                set {_vipchar} to "%{_vipop}%"
            broadcast "{@event_prefix}&a&lTHE VIP SURVIVED! &a&l%{_vipchar}% &a&lis still alive!"
            broadcast "{@event_prefix}&a&lDEFENDERS WIN! &7The target was protected."
            pdRewardTeam("defenders")
    # Faction War — determine winner by kills
    if {_type} is "factionwar":
        set {_t1kills} to 0
        set {_t2kills} to 0
        loop {pd.active.team1::*}:
            set {_k} to {pd.active.kills.%loop-value%}
            if {_k} is set:
                add {_k} to {_t1kills}
        loop {pd.active.team2::*}:
            set {_k} to {pd.active.kills.%loop-value%}
            if {_k} is set:
                add {_k} to {_t2kills}
        if {_t1kills} > {_t2kills}:
            broadcast "{@event_prefix}&9&lTEAM 1 (Heroes) WINS! &7%{_t1kills}% kills vs %{_t2kills}% kills"
            pdRewardTeam("team1")
            pdPenaltyTeam("team2")
        else if {_t2kills} > {_t1kills}:
            broadcast "{@event_prefix}&c&lTEAM 2 (Villains) WINS! &7%{_t2kills}% kills vs %{_t1kills}% kills"
            pdRewardTeam("team2")
            pdPenaltyTeam("team1")
        else:
            broadcast "{@event_prefix}&e&lFACTION WAR TIE! &7Both teams got %{_t1kills}% kills"
            pdRewardTeam("team1")
            pdRewardTeam("team2")
    # Non-team events — reward mode (0=manual, 1=survival, 2=kills, 3=teamkills, 4=lastman)
    if {_type} is not "factionwar":
        set {_mode} to {pd.active.reward_mode}
        if {_mode} is not set:
            set {_mode} to 1
        # Mode 0 — MANUAL: No auto rewards
        if {_mode} is 0:
            broadcast "{@event_prefix}&7Event ended. &eManual mode (0)&7 — admins should use &e/eventwinner &7to reward players."
        # Mode 1 — SURVIVAL: All alive players win
        else if {_mode} is 1:
            if {_type} is not "lore":
                if {pd.active.vip} is not set:
                    set {_survivors::*} to {pd.active.players::*}
                    loop {_survivors::*}:
                        if {pd.active.dead::*} contains loop-value:
                            remove loop-value from {_survivors::*}
                    if size of {_survivors::*} >= 1:
                        broadcast "{@event_prefix}&a&lSURVIVORS WIN! &7%size of {_survivors::*}% players survived!"
                        pdRewardTeam("survivors")
                    else:
                        broadcast "{@event_prefix}&c&lNO SURVIVORS! &7Everyone died!"
        # Mode 2 — KILLS: Top killers win
        else if {_mode} is 2:
            pdRewardTopKillers()
        # Mode 3 — TEAM KILLS (for escort/rescue/protect events)
        else if {_mode} is 3:
            if {_type} is "escort" or {_type} is "rescue" or {_type} is "protect":
                set {_atkKills} to 0
                set {_defKills} to 0
                loop {pd.active.attackers::*}:
                    set {_k} to {pd.active.kills.%loop-value%}
                    if {_k} is set:
                        add {_k} to {_atkKills}
                loop {pd.active.defenders::*}:
                    set {_k} to {pd.active.kills.%loop-value%}
                    if {_k} is set:
                        add {_k} to {_defKills}
                if {_atkKills} > {_defKills}:
                    broadcast "{@event_prefix}&c&lATTACKERS WIN! &7%{_atkKills}% kills vs %{_defKills}% kills"
                    pdRewardTeam("attackers")
                    pdPenaltyTeam("defenders")
                else if {_defKills} > {_atkKills}:
                    broadcast "{@event_prefix}&a&lDEFENDERS WIN! &7%{_defKills}% kills vs %{_atkKills}% kills"
                    pdRewardTeam("defenders")
                    pdPenaltyTeam("attackers")
                else:
                    broadcast "{@event_prefix}&e&lTIE! &7Both sides got %{_atkKills}% kills"
                    pdRewardTeam("attackers")
                    pdRewardTeam("defenders")
            else:
                pdRewardTopKillers()
        # Mode 4 — LAST MAN STANDING
        else if {_mode} is 4:
            set {_lastman} to ""
            loop {pd.active.players::*}:
                if {pd.active.dead::*} does not contain loop-value:
                    set {_lastman} to loop-value
            if {_lastman} is not "":
                set {_lmp} to {_lastman} parsed as offline player
                set {_lmname} to {char.%{_lastman}%.firstname}
                if {_lmname} is not set:
                    set {_lmname} to "%{_lmp}%"
                broadcast "{@event_prefix}&6&lLAST MAN STANDING! &e%{_lmname}% &7is the sole survivor!"
                pdRewardPlayer({_lmp} parsed as player, {pd.active.rep_reward}, {pd.active.xp_reward})
            else:
                broadcast "{@event_prefix}&c&lNO WINNER! &7Everyone died!"
    # BUG 3 FIX: Always show kill leaderboard at event end regardless of reward mode
    pdBroadcastKillLeaderboard({_type})
    # PARTICIPANTS FIX: Restore ALL participants (players + dead + declined)
    set {_allforrestore::*} to {pd.active.participants::*}
    loop {pd.active.dead::*}:
        if {_allforrestore::*} does not contain loop-value:
            add loop-value to {_allforrestore::*}
    loop {pd.active.declined::*}:
        if {_allforrestore::*} does not contain loop-value:
            add loop-value to {_allforrestore::*}
    loop all players:
        if {_allforrestore::*} contains loop-player's uuid:
            set game mode of loop-player to survival
            if {pd.active.dead::*} contains loop-player's uuid:
                send "{@event_prefix}&a&l✓ REVIVED! &7You are back in survival mode." to loop-player
            else if {pd.active.declined::*} contains loop-player's uuid:
                send "{@event_prefix}&a&l✓ Event is over! &7You are back in survival mode." to loop-player
    # Recovery — injured participants recover 1 event
    if {_type} is not "lore":
        loop all players:
            set {_loopuuid} to loop-player's uuid
            if {_allforrestore::*} contains {_loopuuid}:
                pdRecoverOne(loop-player)
    # Give steak to all participants (PD events only)
    if {_type} is not "lore":
        # PARTICIPANTS FIX: Use participants list directly
        set {_allparticipants::*} to {pd.active.participants::*}
        loop {_allparticipants::*}:
            set {_pp} to loop-value parsed as offline player
            if {_pp} is online:
                give {_pp} parsed as player 8 of cooked steak named "&6&lEvent Steak" with lore "&7Thanks for participating!"
    # Run custom reward command if set
    if {pd.active.custom_reward} is set:
        # PARTICIPANTS FIX: Use participants list
        if {_allparticipants::*} is not set:
            set {_allparticipants::*} to {pd.active.participants::*}
        loop {_allparticipants::*}:
            set {_crp} to loop-value parsed as offline player
            if {_crp} is online:
                set {_cmd} to {pd.active.custom_reward}
                replace all "%player%" with "%{_crp}%" in {_cmd}
                make console execute command "%{_cmd}%"
    # Remove main event bossbar using SkBee
    if {pd.active.bossbar} is set:
        set {_bar} to boss bar from id "pd_event"
        if {_bar} is set:
            delete boss bar {_bar}
        delete {pd.active.bossbar}
    # Clean up TAB bossbar placeholders
    set {pd_tab_countdown_active} to "false"
    set {pd_tab_event_active} to "false"
    set {pd_tab_bossbar_title} to ""
    set {pd_tab_bossbar_progress} to "0"
    # Remove countdown bossbar if it exists (in case event ends during countdown)
    set {_cdbar} to boss bar from id "pd_countdown"
    if {_cdbar} is set:
        delete boss bar {_cdbar}
    # Remove event banners
    loop all players:
        set {_loopuuid} to loop-player's uuid
        if {_allforrestore::*} contains {_loopuuid}:
            make console execute command "clear %loop-player% minecraft:blue_banner{display:{Name:'\"\u00a79\u00a7lHero Banner\"'}}"
            make console execute command "clear %loop-player% minecraft:red_banner{display:{Name:'\"\u00a7c\u00a7lVillain Banner\"'}}"
    # Broadcast end
    broadcast "{@event_prefix}&7The &e%{_displaytitle}% &7has ended!"
    send title "&7&lEVENT OVER" with subtitle "&e%{_displaytitle}% Complete" to all players for 3 seconds
    make console execute command "playsound minecraft:ui.toast.challenge_complete master @a ~ ~ ~ 0.5 1"
    # Clean up all event variables
    delete {pd.active}
    delete {pd.active.type}
    delete {pd.active.injury}
    delete {pd.active.pvp}
    delete {pd.active.phase}
    delete {pd.active.players::*}
    delete {pd.active.region}
    delete {pd.active.team1::*}
    delete {pd.active.team2::*}
    delete {pd.active.dead::*}
    delete {pd.active.bossbar}
    delete {pd.active.vip}
    delete {pd.active.attackers::*}
    delete {pd.active.defenders::*}
    delete {pd.active.rep_reward}
    delete {pd.active.xp_reward}
    delete {pd.active.bucks_reward}
    delete {pd.active.respawn_mode}
    delete {pd.active.injury}
    delete {pd.active.lore_text}
    delete {pd.active.duration}
    delete {pd.active.title}
    delete {pd.active.kills::*}
    delete {pd.active.team1_spawn}
    delete {pd.active.team2_spawn}
    delete {pd.active.custom_reward}
    delete {pd.active.declined::*}
    delete {pd.active.start_time}
    delete {pd.active.reward_mode}
    # Restore original chatname preferences
    loop all players:
        if {_allforrestore::*} contains loop-player's uuid:
            set {_chatuuid} to loop-player's uuid
            if {pd.eventchatname.%{_chatuuid}%} is set:
                set {char.%{_chatuuid}%.usemcname} to true
                delete {pd.eventchatname.%{_chatuuid}%}
            else:
                delete {char.%{_chatuuid}%.usemcname}
            updateCharacterDisplay(loop-player)
            syncPlayerMeta(loop-player)

# ============================================================
# BUG 3 FIX — Always broadcast kill leaderboard at event end
# BUG 3 FIX — Leaderboard adapts label based on event type
# ============================================================

function pdBroadcastKillLeaderboard(type: text):
    # PARTICIPANTS FIX: Use participants list (includes ALL who joined, never removed)
    set {_allp::*} to {pd.active.participants::*}
    # Initialize 0 kills for anyone not in the kills list
    loop {_allp::*}:
        if {pd.active.kills.%loop-value%} is not set:
            set {pd.active.kills.%loop-value%} to 0
    # Find top 5 killers
    set {_top1} to ""
    set {_top2} to ""
    set {_top3} to ""
    set {_top4} to ""
    set {_top5} to ""
    set {_top1k} to 0
    set {_top2k} to 0
    set {_top3k} to 0
    set {_top4k} to 0
    set {_top5k} to 0
    loop {_allp::*}:
        set {_ku} to loop-value
        set {_kv} to {pd.active.kills.%{_ku}%}
        if {_kv} is not set:
            set {_kv} to 0
        if {_kv} > {_top1k}:
            set {_top5} to {_top4}
            set {_top5k} to {_top4k}
            set {_top4} to {_top3}
            set {_top4k} to {_top3k}
            set {_top3} to {_top2}
            set {_top3k} to {_top2k}
            set {_top2} to {_top1}
            set {_top2k} to {_top1k}
            set {_top1} to {_ku}
            set {_top1k} to {_kv}
        else if {_kv} > {_top2k}:
            set {_top5} to {_top4}
            set {_top5k} to {_top4k}
            set {_top4} to {_top3}
            set {_top4k} to {_top3k}
            set {_top3} to {_top2}
            set {_top3k} to {_top2k}
            set {_top2} to {_ku}
            set {_top2k} to {_kv}
        else if {_kv} > {_top3k}:
            set {_top5} to {_top4}
            set {_top5k} to {_top4k}
            set {_top4} to {_top3}
            set {_top4k} to {_top3k}
            set {_top3} to {_ku}
            set {_top3k} to {_kv}
        else if {_kv} > {_top4k}:
            set {_top5} to {_top4}
            set {_top5k} to {_top4k}
            set {_top4} to {_ku}
            set {_top4k} to {_kv}
        else if {_kv} > {_top5k}:
            set {_top5} to {_ku}
            set {_top5k} to {_kv}
    # Build sorted list of ALL participants by kills (descending)
    set {_sorted::*} to sorted {_allp::*} where [input.getKillCount(.)] is ordered from highest to lowest
    # Helper: get kill count for sorting (this is a comment, actual sorting done differently)
    # Build a list of all participants with their kill counts for display
    set {_plist::*} to {_allp::*}
    # Sort manually by creating indexed values
    loop {_plist::*}:
        set {_ku} to loop-value
        set {_kv} to {pd.active.kills.%{_ku}%}
        if {_kv} is not set:
            set {_kv} to 0
        set {_index.%{_kv}%::*} to {_index.%{_kv}%::*}, {_ku}
    # Collect in descending order
    set {_displayorder::*} to []
    set {_maxk} to 0
    loop {_plist::*}:
        set {_kcheck} to {pd.active.kills.%loop-value%}
        if {_kcheck} is not set:
            set {_kcheck} to 0
        if {_kcheck} > {_maxk}:
            set {_maxk} to {_kcheck}
    loop {_maxk} + 1 times:
        set {_kloop} to {_maxk} - (loop-number - 1)
        if {_index.%{_kloop}%::*} is set:
            loop {_index.%{_kloop}%::*}:
                add loop-value-2 to {_displayorder::*}
    # Broadcast the leaderboard
    broadcast "&8&m                                                    "
    broadcast ""
    broadcast "  &6&l⚔ Kill Leaderboard ⚔ &7(%size of {_allp::*}% participants)"
    # BUG 3 FIX: Label shows survivors context if it was a survivors event
    if {_type} is "survivors":
        broadcast "  &7(Survivors Event — kill count shown for competitiveness)"
    broadcast ""
    # Show top 5 with medals
    set {_pos} to 0
    loop {_displayorder::*}:
        add 1 to {_pos}
        if {_pos} > 10:
            stop loop
        set {_uuid} to loop-value
        set {_p} to {_uuid} parsed as offline player
        set {_pname} to "%{_p}%"
        set {_pk} to {pd.active.kills.%{_uuid}%}
        if {_pk} is not set:
            set {_pk} to 0
        if {_pos} is 1:
            broadcast "  &6&l🥇 1st: &e%{_pname}% &8— &c%{_pk}% kills"
        else if {_pos} is 2:
            broadcast "  &7&l🥈 2nd: &e%{_pname}% &8— &c%{_pk}% kills"
        else if {_pos} is 3:
            broadcast "  &7&l🥉 3rd: &e%{_pname}% &8— &c%{_pk}% kills"
        else:
            broadcast "  &8%{_pos}th: &e%{_pname}% &8— &c%{_pk}% kills"
    if size of {_displayorder::*} is 0:
        broadcast "  &8No participants recorded."
    broadcast ""
    broadcast "&8&m                                                    "
    # Cleanup
    loop {_plist::*}:
        delete {_index.%{pd.active.kills.%loop-value%}%::*}

