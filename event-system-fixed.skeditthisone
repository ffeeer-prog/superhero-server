# ============================================================
# AUTO TEAM ASSIGNMENT FUNCTION
# Assigns unassigned players to balance teams
# Rule: team1_size - team2_size <= 1
# ============================================================

function pdAutoAssignTeams():
    set {_unassigned::*} to {pd.active.players::*}
    loop {pd.active.team1::*}:
        remove loop-value from {_unassigned::*}
    loop {pd.active.team2::*}:
        remove loop-value from {_unassigned::*}
    if size of {_unassigned::*} = 0:
        stop
    send "{@prefix}&7Auto-assigning &e%size of {_unassigned::}% &7players to teams..." to all players
    loop {_unassigned::*}:
        set {_uuid} to loop-value
        set {_t1size} to size of {pd.active.team1::*}
        set {_t2size} to size of {pd.active.team2::*}
        set {_p} to {_uuid} parsed as offline player
        # Assign to smaller team, or random if equal
        if {_t1size} < {_t2size}:
            add {_uuid} to {pd.active.team1::*}
            if {_p} is online:
                make console execute command "give %{_p}% minecraft:blue_banner{display:{Name:'\"\u00a79\u00a7lHero Banner\"',Lore:['\"\u00a77Team 1 - Heroes\"','\"\u00a77Fight for justice!\"','\"\u00a78Event Item - Returns after event\"']},pd_banner:1b,Unbreakable:1b,HideFlags:255} 1"
                send "{@event_prefix}&7Auto-assigned to &9Team 1 (Heroes)&7!" to {_p} parsed as player
        else if {_t2size} < {_t1size}:
            add {_uuid} to {pd.active.team2::*}
            if {_p} is online:
                make console execute command "give %{_p}% minecraft:red_banner{display:{Name:'\"\u00a7c\u00a7lVillain Banner\"',Lore:['\"\u00a77Team 2 - Villains\"','\"\u00a77Embrace the darkness!\"','\"\u00a78Event Item - Returns after event\"']},pd_banner:1b,Unbreakable:1b,HideFlags:255} 1"
                send "{@event_prefix}&7Auto-assigned to &cTeam 2 (Villains)&7!" to {_p} parsed as player
        else:
            # Equal size — random assignment
            set {_rand} to random integer between 1 and 2
            if {_rand} is 1:
                add {_uuid} to {pd.active.team1::*}
                if {_p} is online:
                    make console execute command "give %{_p}% minecraft:blue_banner{display:{Name:'\"\u00a79\u00a7lHero Banner\"',Lore:['\"\u00a77Team 1 - Heroes\"','\"\u00a77Fight for justice!\"','\"\u00a78Event Item - Returns after event\"']},pd_banner:1b,Unbreakable:1b,HideFlags:255} 1"
                    send "{@event_prefix}&7Auto-assigned to &9Team 1 (Heroes)&7!" to {_p} parsed as player
            else:
                add {_uuid} to {pd.active.team2::*}
                if {_p} is online:
                    make console execute command "give %{_p}% minecraft:red_banner{display:{Name:'\"\u00a7c\u00a7lVillain Banner\"',Lore:['\"\u00a77Team 2 - Villains\"','\"\u00a77Embrace the darkness!\"','\"\u00a78Event Item - Returns after event\"']},pd_banner:1b,Unbreakable:1b,HideFlags:255} 1"
                    send "{@event_prefix}&7Auto-assigned to &cTeam 2 (Villains)&7!" to {_p} parsed as player

