command /eventwinner <player> [<integer>] [<integer>]:
    permission: klawcraft.admin
    description: Reward a lore event winner with rep and XP
    trigger:
        set {_rep} to arg-2
        if {_rep} is not set:
            set {_rep} to 5
        set {_xp} to arg-3
        if {_xp} is not set:
            set {_xp} to 0
        set {_uuid} to arg-1's uuid
        pdInit(arg-1)
        add {_rep} to {pd.%{_uuid}%.reputation}
        if {_xp} > 0:
            set {_curlevel} to arg-1's level
            set arg-1's level to {_curlevel} + {_xp}
        pdUpdateStars(arg-1)
        pdSyncMeta(arg-1)
        send "{@event_prefix}&6&l+%{_rep}% Reputation &7and &6&l+%{_xp}% XP Levels &7for winning the event!" to arg-1
        send "{@prefix}&7Gave &e%arg-1% &7%{_rep}% rep and %{_xp}% XP."

# ============================================================
# REPUTATION — Check your rep and stars
# ============================================================

command /reputation:
    aliases: /rep, /myrep, /stars
    description: Check your reputation and star rank
    trigger:
        pdInit(player)
        set {_uuid} to player's uuid
        set {_rep} to {pd.%{_uuid}%.reputation}
        set {_stars} to {pd.%{_uuid}%.stars}
        set {_status} to {pd.%{_uuid}%.status}
        set {_stardisplay} to ""
        loop {_stars} times:
            set {_stardisplay} to "%{_stardisplay}%&6★"
        if {_stars} is 6:
            set {_stardisplay} to "&6S★"
        else if {_stars} is 7:
            set {_stardisplay} to "&6SS★"
        else if {_stars} is 8:
            set {_stardisplay} to "&6SSS★"
        set {_nextrep} to "MAX"
        if {_stars} < 5:
            if {_stars} is 1:
                set {_nextrep} to {@star2}
            else if {_stars} is 2:
                set {_nextrep} to {@star3}
            else if {_stars} is 3:
                set {_nextrep} to {@star4}
            else if {_stars} is 4:
                set {_nextrep} to {@star5}
        set {_needed} to 0
        if {_nextrep} is not "MAX":
            set {_needed} to {_nextrep} - {_rep}
            if {_needed} < 0:
                set {_needed} to 0
        set {_statusdisplay} to "&a&lAlive"
        if {_status} is "injured":
            set {_statusdisplay} to "&4&lInjured"
        else if {_status} is "dead":
            set {_statusdisplay} to "&4&lDEAD"
        send "" to player
        send "&8&m                                                    " to player
        send "  &6&l★ Reputation & Stars ★" to player
        send "" to player
        send "  &7Star Rank: %{_stardisplay}% &7(&e%{_stars}%&7)" to player
        send "  &7Reputation: &e%{_rep}%" to player
        if {_nextrep} is not "MAX":
            send "  &7Next Star at: &e%{_nextrep}% rep &7(&a%{_needed}% more needed&7)" to player
        else:
            send "  &7Next Star: &6MAX RANK" to player
        send "  &7Status: %{_statusdisplay}%" to player
        if {_status} is "injured":
            send "  &7Events Locked: &c%{pd.%{_uuid}%.injury_remaining}%" to player
        else if {_status} is "dead":
            send "  &7Use &e/resurrect &7or &e/hospital &7to revive" to player
        send "  &7Events Played: &e%{pd.%{_uuid}%.events_played}%" to player
        send "  &7Kills: &e%{pd.%{_uuid}%.event_kills}% &7| Deaths: &c%{pd.%{_uuid}%.event_deaths}%" to player
        send "&8&m                                                    " to player
        send "" to player

