        if {pd.%{_uuid}%.status} is not "dead":
            send "{@prefix}&e%arg-1% &7is not dead."
            stop
        set {pd.%{_uuid}%.status} to "alive"
        set {pd.%{_uuid}%.injury_tier} to 0
        set {pd.%{_uuid}%.injury_remaining} to 0
