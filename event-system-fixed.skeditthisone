# ============================================================
# KlawCraft: Era of Supes — Permadeath Event & Lore Event System
# FIXED VERSION — All 10 bugs patched + new features added
# ============================================================
# FIXES APPLIED:
#   BUG 1:  Added /kcshouttitle and /kcshoutactionbar commands
#   BUG 2:  Added event history tracking + /eventhistory command
#   BUG 3:  Kill counter always shown; leaderboard adapts to event type
#   BUG 4:  Bossbar completely rewritten — uses vanilla commands properly
#   BUG 5:  Event title now shown in boss bar, countdown header, and /eventstatus
#   BUG 6:  Timer now works correctly — countdown integer added to /startpd
#           Injury option added to /startpd as a named arg
#   BUG 7:  On join, injured/dead players are ALWAYS put in spectator if event active
#           regardless of whether they were previously in the event
#   BUG 8:  On join, players who died in the event are LOCKED to spectator
#           until the event ends, regardless of relog
#   BUG 9:  Countdown timer integer now works in /startpd (cd:N or countdown:N)
#           Title displayed correctly during countdown
#   BUG 10: Death notifications now announce who died, kills, and remaining count
#           Faction/escort events announce team remaining count
# ============================================================

options:
    prefix: &8[&c&lKC&8] &7
    event_prefix: &8[&4&lPD&8] &7
    lore_prefix: &8[&b&lLore&8] &7
    star1: 5
    star2: 15
    star3: 30
    star4: 45
    star5: 75
    hospital_cost: 10000
    leave_xp_penalty: 10
    leave_rep_penalty: 5
    countdown_seconds: 25
    default_duration: 600
    lore_crate: lore

# ============================================================
# DATA MODEL
# ============================================================
# {pd.%uuid%.status}              — "alive", "injured", or "dead"
# {pd.%uuid%.injury_tier}         — int
# {pd.%uuid%.injury_remaining}    — int
# {pd.%uuid%.reputation}          — int
# {pd.%uuid%.stars}               — int (1-8)
# {pd.%uuid%.event_deaths}        — int
# {pd.%uuid%.events_played}       — int
# {pd.%uuid%.event_kills}         — int (lifetime)
#
# {pd.active}                     — true/false
# {pd.active.type}                — event type string
# {pd.active.injury}              — true/false
# {pd.active.pvp}                 — true/false
# {pd.active.players::*}          — list of UUIDs in event
# {pd.active.phase}               — "idle"/"countdown"/"active"/"ending"
# {pd.active.region}              — WorldGuard region name
# {pd.active.team1::*}            — team 1 UUIDs
# {pd.active.team2::*}            — team 2 UUIDs
# {pd.active.bossbar}             — bossbar ID or "pd_event_tab"
# {pd.active.bucks_reward}        — Bucks reward amount
# {pd.active.respawn_mode}        — true/false
# {pd.active.start_time}          — timestamp
# TAB bossbar placeholders (via PlaceholderAPI + skript-placeholders):
# {pd_tab_countdown_active}       — "true"/"false" for countdown bossbar
# {pd_tab_event_active}           — "true"/"false" for active bossbar
# {pd_tab_bossbar_title}          — bossbar title text
# {pd_tab_bossbar_progress}       — bossbar progress 0-100
# {pd.active.dead::*}             — UUIDs who died (locked to spectator)
# {pd.active.bossbar}             — bossbar ID
# {pd.active.vip}                 — UUID of the VIP/target
# {pd.active.attackers::*}        — attacker UUIDs
# {pd.active.defenders::*}        — defender UUIDs
# {pd.active.rep_reward}          — rep reward for winners
# {pd.active.xp_reward}           — XP reward
# {pd.active.bucks_reward}        — Bucks reward
# {pd.active.lore_text}           — lore/story text
# {pd.active.duration}            — event duration in seconds
# {pd.active.title}               — custom event title
# {pd.active.kills.%uuid%}        — kill counter per player this event
# {pd.active.team1_spawn}         — team 1 spawn location
# {pd.active.team2_spawn}         — team 2 spawn location
# {pd.active.custom_reward}       — custom reward command
# {pd.active.declined::*}         — players who declined
# {pd.active.reward_mode}         — 0=manual, 1=survival, 2=kills, 3=teamkills, 4=lastman
# {pd.active.respawn_mode}        — true=normal respawn, false=spectator on death
# {pd.active.injury}              — true/false (injury enabled during event)
# {pd.active.start_time}          — system time when event went active
# {pd.active.participants::*}     — ALL players who joined (never removed until end)
# {pd.minplayers.enabled}         — true/false (enable min player check)
# {pd.lastattacker.%uuid%}        — last player who damaged this player (for kill tracking)
#
# EVENT HISTORY (persisted):
# {pd.history.count}              — total events run
# {pd.history.%N%.type}           — type of event N
# {pd.history.%N%.title}          — title of event N
# {pd.history.%N%.date}           — date/time string
# {pd.history.%N%.winners::*}     — winner UUIDs
# {pd.history.%N%.top_killer}     — UUID of top killer
# {pd.history.%N%.top_kills}      — kills of top killer
# {pd.history.%N%.participants}   — total participant count

# ============================================================
# HELPER FUNCTIONS
# ============================================================

function pdInit(p: player):
    set {_uuid} to {_p}'s uuid
    if {pd.%{_uuid}%.status} is not set:
        set {pd.%{_uuid}%.status} to "alive"
    if {pd.%{_uuid}%.injury_tier} is not set:
        set {pd.%{_uuid}%.injury_tier} to 0
    if {pd.%{_uuid}%.injury_remaining} is not set:
        set {pd.%{_uuid}%.injury_remaining} to 0
    if {pd.%{_uuid}%.reputation} is not set:
        set {pd.%{_uuid}%.reputation} to 0
    if {pd.%{_uuid}%.stars} is not set:
        set {pd.%{_uuid}%.stars} to 1
    if {pd.%{_uuid}%.event_deaths} is not set:
        set {pd.%{_uuid}%.event_deaths} to 0
    if {pd.%{_uuid}%.events_played} is not set:
        set {pd.%{_uuid}%.events_played} to 0
    if {pd.%{_uuid}%.event_kills} is not set:
        set {pd.%{_uuid}%.event_kills} to 0

function pdGetStarFromRep(rep: integer) :: integer:
    if {_rep} >= {@star5}:
        return 5
    else if {_rep} >= {@star4}:
        return 4
    else if {_rep} >= {@star3}:
        return 3
    else if {_rep} >= {@star2}:
        return 2
    else if {_rep} >= {@star1}:
        return 1
    return 1

function pdUpdateStars(p: player):
    set {_uuid} to {_p}'s uuid
    set {_oldstars} to {pd.%{_uuid}%.stars}
    set {_newstars} to pdGetStarFromRep({pd.%{_uuid}%.reputation})
    if {_newstars} > {_oldstars}:
        set {pd.%{_uuid}%.stars} to {_newstars}
        set {_pname} to {_p}'s name
        execute console command "lp user %{_pname}% parent remove 1-star"
        execute console command "lp user %{_pname}% parent remove 2-star"
        execute console command "lp user %{_pname}% parent remove 3-star"
        execute console command "lp user %{_pname}% parent remove 4-star"
        execute console command "lp user %{_pname}% parent remove 5-star"
        execute console command "lp user %{_pname}% parent remove S-star"
        execute console command "lp user %{_pname}% parent remove SS-star"
        execute console command "lp user %{_pname}% parent remove SSS-star"
        wait 3 ticks
        set {_group} to "%{_newstars}%-star"
        if {_newstars} is 6:
            set {_group} to "S-star"
        else if {_newstars} is 7:
            set {_group} to "SS-star"
        else if {_newstars} is 8:
            set {_group} to "SSS-star"
        execute console command "lp user %{_pname}% parent add %{_group}%"
        execute console command "crates key give %{_p}% {@lore_crate} 1"
        set {_stardisplay} to "%{_newstars}%★"
        if {_newstars} is 6:
            set {_stardisplay} to "S★"
        else if {_newstars} is 7:
            set {_stardisplay} to "SS★"
        else if {_newstars} is 8:
            set {_stardisplay} to "SSS★"
        send "{@event_prefix}&6&l★ STAR UP! ★ &7You are now a &e%{_stardisplay}% &7Supe!" to {_p}
        send "{@event_prefix}&7You received a &b&lLore Crate Key&7!" to {_p}
        make console execute command "playsound minecraft:ui.toast.challenge_complete master %{_pname}% ~ ~ ~ 1 1"
    else if {_newstars} < {_oldstars}:
        set {pd.%{_uuid}%.stars} to {_newstars}
        set {_pname} to {_p}'s name
        execute console command "lp user %{_pname}% parent remove 1-star"
        execute console command "lp user %{_pname}% parent remove 2-star"
        execute console command "lp user %{_pname}% parent remove 3-star"
        execute console command "lp user %{_pname}% parent remove 4-star"
        execute console command "lp user %{_pname}% parent remove 5-star"
        execute console command "lp user %{_pname}% parent remove S-star"
        execute console command "lp user %{_pname}% parent remove SS-star"
        execute console command "lp user %{_pname}% parent remove SSS-star"
        wait 3 ticks
        if {_newstars} > 0:
            set {_group} to "%{_newstars}%-star"
            if {_newstars} is 6:
                set {_group} to "S-star"
            else if {_newstars} is 7:
                set {_group} to "SS-star"
            else if {_newstars} is 8:
                set {_group} to "SSS-star"
            execute console command "lp user %{_pname}% parent add %{_group}%"
        send "{@event_prefix}&c&l★ STAR LOST ★ &7You dropped to a lower star rank." to {_p}

function pdSyncMeta(p: player):
    set {_uuid} to {_p}'s uuid
    set {_pname} to {_p}'s name
    set {_rep} to {pd.%{_uuid}%.reputation}
    if {_rep} is not set:
        set {_rep} to 0
    set {_stars} to {pd.%{_uuid}%.stars}
    if {_stars} is not set:
        set {_stars} to 1
    set {_status} to {pd.%{_uuid}%.status}
    if {_status} is not set:
        set {_status} to "alive"
    execute console command "lp user %{_pname}% meta set reputation %{_rep}%"
    execute console command "lp user %{_pname}% meta set stars %{_stars}%"
    execute console command "lp user %{_pname}% meta set pd_status %{_status}%"
    set {_inj} to {pd.%{_uuid}%.injury_remaining}
    if {_inj} is not set:
        set {_inj} to 0
    execute console command "lp user %{_pname}% meta set injury_remaining %{_inj}%"

# ============================================================
# BUG 7 & 8 FIX — ON JOIN: Enforce spectator for injured/dead
# and for players who already died during the active event
# ============================================================

on join:
    wait 3 seconds
    pdInit(player)
    pdSyncMeta(player)
    set {_uuid} to player's uuid
    if {pd.active} is true:
        if {pd.active.phase} is "active":
            # BUG 8 FIX: Players who DIED during the event stay locked in spectator on rejoin
            if {pd.active.dead::*} contains {_uuid}:
                set player's game mode to spectator
                send "{@event_prefix}&cYou died in the event and cannot re-enter." to player
                send "{@event_prefix}&7Wait for the event to end." to player
                stop
            # BUG 7 FIX: Players who are injured or dead (status) go to spectator
            if {pd.%{_uuid}%.status} is "injured":
                set player's game mode to spectator
                send "{@event_prefix}&cYou are &4&lINJURED&c and cannot join the active event." to player
                send "{@event_prefix}&7You are in spectator mode. Wait for the event to end." to player
                stop
            if {pd.%{_uuid}%.status} is "dead":
                set player's game mode to spectator
                send "{@event_prefix}&cYou are &4&lDEAD&c and cannot join the active event." to player
                send "{@event_prefix}&7Use &e/resurrect&7 or &e/hospital&7 after the event." to player
                stop
            # BUG 8 FIX: If player was in the declined list, keep them in spectator
            if {pd.active.declined::*} contains {_uuid}:
                set player's game mode to spectator
                send "{@event_prefix}&7You are spectating until the event ends." to player
                stop
            # NEW PLAYER JOINING DURING ACTIVE EVENT: Auto-decline and spectator
            if {pd.active.players::*} does not contain {_uuid}:
                if {pd.active.participants::*} does not contain {_uuid}:
                    add {_uuid} to {pd.active.declined::*}
                    set player's game mode to spectator
                    give player 1 cookie named "&6&lGood Sport Cookie" with lore "&7Thanks for waiting!"
                    send "{@event_prefix}&7An event is in progress. You've been put in &eSpectator&7 mode." to player
                    send "{@event_prefix}&7Wait for the event to end to play normally." to player
                    stop
    # Apply death weakness for "dead" status players
    if {pd.%player's uuid%.status} is "dead":
        make console execute command "effect give %player% minecraft:weakness 999999 1 true"

# Prevent banner drops during events
on drop:
    if {pd.active} is true:
        if name of event-item is "&9&lHero Banner" or "&c&lVillain Banner":
            send "{@event_prefix}&cYou cannot drop your team banner during an event!" to player
            cancel event
        if event-item has nbt "pd_banner":
            send "{@event_prefix}&cEvent items cannot be dropped!" to player
            cancel event

on inventory click:
    if {pd.active} is true:
        if name of event-item is "&9&lHero Banner" or "&c&lVillain Banner":
            if event-inventory is not player's inventory:
                send "{@event_prefix}&cYou cannot place your banner in containers during an event!" to player
                cancel event
        if event-item has nbt "pd_banner":
            if event-inventory is not player's inventory:
                send "{@event_prefix}&cEvent items cannot be moved to containers!" to player
                cancel event

# ============================================================
# INJURY SYSTEM
# ============================================================

function pdApplyInjury(p: player):
    set {_uuid} to {_p}'s uuid
    add 1 to {pd.%{_uuid}%.injury_tier}
    set {pd.%{_uuid}%.injury_remaining} to {pd.%{_uuid}%.injury_tier}
    add 1 to {pd.%{_uuid}%.event_deaths}
    if {pd.%{_uuid}%.injury_tier} >= 4:
        set {pd.%{_uuid}%.status} to "dead"
        make console execute command "effect give %{_p}% minecraft:weakness 999999 1 true"
        pdSyncMeta({_p})
        send "" to {_p}
        send "&8&m                                                    " to {_p}
        send "  &4&l☠ DEAD ☠" to {_p}
        send "" to {_p}
        send "  &7You have been &4&lKILLED&7 during a Permadeath Event!" to {_p}
        send "  &7Injury Tier: &c%{pd.%{_uuid}%.injury_tier}% &7(Dead)" to {_p}
        send "  &7Events Locked: &c%{pd.%{_uuid}%.injury_remaining}%" to {_p}
        send "" to {_p}
        send "  &7You are &4&lDEAD&7. Use &e/resurrect &7(&a20,000 Bucks&7) to revive" to {_p}
        send "  &7Or use &e/hospital &7(&a10,000 Bucks&7) to revive" to {_p}
        send "&8&m                                                    " to {_p}
        send "" to {_p}
        make console execute command "playsound minecraft:entity.wither.death master %{_p}% ~ ~ ~ 0.5 0.5"
    else:
        set {pd.%{_uuid}%.status} to "injured"
        pdSyncMeta({_p})
        send "" to {_p}
        send "&8&m                                                    " to {_p}
        send "  &4&l⚠ INJURED ⚠" to {_p}
        send "" to {_p}
        send "  &7You have been &4&lINJURED&7 during a Permadeath Event!" to {_p}
        send "  &7Injury Tier: &c%{pd.%{_uuid}%.injury_tier}%" to {_p}
        send "  &7Events Locked: &c%{pd.%{_uuid}%.injury_remaining}%" to {_p}
        send "" to {_p}
        send "  &7Recover by waiting &e%{pd.%{_uuid}%.injury_remaining}% events&7" to {_p}
        send "  &7Or use &e/hospital &7(&a10,000 Bucks&7) to heal instantly" to {_p}
        send "&8&m                                                    " to {_p}
        send "" to {_p}
        make console execute command "playsound minecraft:entity.wither.death master %{_p}% ~ ~ ~ 0.5 0.8"

function pdRecoverOne(p: player):
    set {_uuid} to {_p}'s uuid
    if {pd.%{_uuid}%.status} is "injured":
        remove 1 from {pd.%{_uuid}%.injury_remaining}
        if {pd.%{_uuid}%.injury_remaining} <= 0:
            set {pd.%{_uuid}%.status} to "alive"
            set {pd.%{_uuid}%.injury_remaining} to 0
            make console execute command "effect clear %{_p}% minecraft:weakness"
            send "{@event_prefix}&a&l✓ RECOVERED! &7You are no longer injured!" to {_p}
            make console execute command "playsound minecraft:entity.player.levelup master %{_p}% ~ ~ ~ 0.5 1.2"
        else:
            send "{@event_prefix}&7Injury recovery: &e%{pd.%{_uuid}%.injury_remaining}% &7event(s) remaining." to {_p}
        pdSyncMeta({_p})
    else if {pd.%{_uuid}%.status} is "dead":
        send "{@event_prefix}&7You are &4&lDEAD&7. Use &e/resurrect &7(&a20k Bucks&7) or &e/hospital &7(&a10k Bucks&7)." to {_p}

# ============================================================
# HOSPITAL COMMAND
# ============================================================

command /hospital:
    description: Heal your injury instantly (costs 10,000 Bucks)
    trigger:
        pdInit(player)
        set {_uuid} to player's uuid
        if {pd.%{_uuid}%.status} is not "injured" and {pd.%{_uuid}%.status} is not "dead":
            send "{@prefix}&aYou are not injured!"
            stop
        set {_bal} to player's balance
        if {_bal} < {@hospital_cost}:
            send "{@prefix}&cYou need &a10,000 Bucks &cto use the hospital!"
            send "{@prefix}&7Your balance: &a%{_bal}% Bucks"
            stop
        execute console command "eco take %player% {@hospital_cost}"
        set {pd.%{_uuid}%.status} to "alive"
        set {pd.%{_uuid}%.injury_tier} to 0
        set {pd.%{_uuid}%.injury_remaining} to 0
        remove weakness from player
        pdSyncMeta(player)
        send "" to player
        send "&8&m                                                    " to player
        send "  &a&l✦ HOSPITAL — FULLY HEALED ✦" to player
        send "" to player
        send "  &7Cost: &a10,000 Bucks &7(deducted)" to player
        send "  &7Status: &aAlive" to player
        send "  &7Injury Tier: &e0" to player
        send "&8&m                                                    " to player
        send "" to player
        make console execute command "playsound minecraft:entity.player.levelup master %player% ~ ~ ~ 1 1"

# ============================================================
# REPUTATION COMMANDS
# ============================================================

command /pdbonus <player> <integer>:
    permission: klawcraft.admin
    description: Give reputation bonus to a player
    trigger:
        if arg-2 <= 0:
            send "{@prefix}&cAmount must be positive."
            stop
        set {_uuid} to arg-1's uuid
        pdInit(arg-1)
        add arg-2 to {pd.%{_uuid}%.reputation}
        pdUpdateStars(arg-1)
        pdSyncMeta(arg-1)
        send "{@prefix}&7Gave &e%arg-2% &7reputation to &e%arg-1%&7. Total: &e%{pd.%{_uuid}%.reputation}%&7 ★%{pd.%{_uuid}%.stars}%" to player
        if arg-1 is online:
            send "{@event_prefix}&7You received &e%arg-2% &7reputation! Total: &e%{pd.%{_uuid}%.reputation}%&7 ★%{pd.%{_uuid}%.stars}%" to arg-1

command /pdrep [<player>]:
    aliases: /reputation, /rep
    description: Check your or another player's reputation
    trigger:
        if arg-1 is set:
            if player does not have permission "klawcraft.admin":
                send "{@prefix}&cNo permission."
                stop
            set {_target} to arg-1
        else:
            set {_target} to player
        set {_uuid} to {_target}'s uuid
        pdInit({_target})
        set {_rep} to {pd.%{_uuid}%.reputation}
        set {_stars} to {pd.%{_uuid}%.stars}
        set {_status} to {pd.%{_uuid}%.status}
        set {_inj} to {pd.%{_uuid}%.injury_remaining}
        set {_deaths} to {pd.%{_uuid}%.event_deaths}
        set {_played} to {pd.%{_uuid}%.events_played}
        send "" to player
        send "&8&m                                                    " to player
        send "  &c&l✦ Supe Record — %{_target}%" to player
        send "" to player
        send "  &7Reputation: &e%{_rep}%" to player
        set {_stardisplay} to ""
        loop {_stars} times:
            set {_stardisplay} to "%{_stardisplay}%&6★"
        send "  &7Stars: %{_stardisplay}% &8(%{_stars}%/5)" to player
        send "  &7Status: &e%{_status}%" to player
        if {_status} is "injured":
            send "  &7Events Locked: &c%{_inj}%" to player
        send "  &7Event Deaths: &c%{_deaths}%" to player
        send "  &7Events Played: &a%{_played}%" to player
        if {_stars} < 5:
            if {_stars} is 1:
                set {_next} to {@star2}
            else if {_stars} is 2:
                set {_next} to {@star3}
            else if {_stars} is 3:
                set {_next} to {@star4}
            else if {_stars} is 4:
                set {_next} to {@star5}
            set {_need} to {_next} - {_rep}
            send "" to player
            send "  &7Next Star in: &e%{_need}% &7reputation" to player
        send "&8&m                                                    " to player
        send "" to player

# ============================================================
# BUG 1 FIX — ADMIN SHOUT COMMANDS
# /kcshouttitle <message>       — sends message as a title to all players
# /kcshoutactionbar <message>   — sends message as an actionbar to all players
# ============================================================

command /kcshouttitle <text>:
    permission: klawcraft.admin
    description: Send a title message to all players
    trigger:
        set {_msg} to arg-1
        send title "&6&l%{_msg}%" with subtitle "" to all players for 5 seconds
        make console execute command "playsound minecraft:entity.ender_dragon.growl master @a ~ ~ ~ 0.3 1"
        send "{@prefix}&7Title sent: &e%{_msg}%" to player

command /kcshoutactionbar <text>:
    permission: klawcraft.admin
    description: Send an actionbar message to all players
    trigger:
        set {_msg} to arg-1
        send action bar "&6&l%{_msg}%" to all players
        send "{@prefix}&7Actionbar sent: &e%{_msg}%" to player

# ============================================================
# PERMADEATH EVENT — START
# BUG 6 & 9 FIX: countdown integer now works, injury flag added
# Usage: /startpd <type> [title:X] [rep:N] [xp:N] [dur:N or time:N]
#                        [cd:N or countdown:N] [injury:true/false] [region:Name]
# Example: /startpd roam title:Viltrumites rep:10000 xp:50000 dur:1800 cd:30
# ============================================================

command /startpd <text> [<text>] [<text>] [<text>] [<text>] [<text>] [<text>] [<text>] [<text>] [<text>] [<text>] [<text>] [<text>] [<text>] [<text>]:
    permission: klawcraft.admin
    description: Start a PD Event. Skript handles quotes natively — use "My Title" for spaces.
    trigger:
        if {pd.active} is true:
            send "{@prefix}&cAn event is already running! Use &e/endevent &cto end it first."
            stop
        set {_type} to lowercase arg-1
        set {_valid} to false
        if {_type} is "roam":
            set {_valid} to true
        else if {_type} is "elimination":
            set {_valid} to true
        else if {_type} is "factionwar":
            set {_valid} to true
        else if {_type} is "hunted":
            set {_valid} to true
        else if {_type} is "escort":
            set {_valid} to true
        else if {_type} is "rescue":
            set {_valid} to true
        else if {_type} is "protect":
            set {_valid} to true
        else if {_type} is "controlzone":
            set {_valid} to true
        else if {_type} is "blackout":
            set {_valid} to true
        else if {_type} is "supplydrop":
            set {_valid} to true
        else if {_type} is "survivors":
            set {_valid} to true
        if {_valid} is false:
            send "{@prefix}&cInvalid event type!"
            send "{@prefix}&7Types: &eroam&7, &eelimination&7, &efactionwar&7, &ehunted&7, &eescort&7, &erescue&7, &eprotect&7, &econtrolzone&7, &eblackout&7, &esupplydrop&7, &esurvivors"
            stop
        # Save pre-event settings
        set {_saved_title} to {pd.active.title}
        set {_saved_lore} to {pd.active.lore_text}
        set {_saved_reward} to {pd.active.custom_reward}
        set {_saved_t1spawn} to {pd.active.team1_spawn}
        set {_saved_t2spawn} to {pd.active.team2_spawn}
        # Defaults
        set {pd.active.rep_reward} to 5
        set {pd.active.xp_reward} to 0
        set {pd.active.bucks_reward} to 0
        set {pd.active.respawn_mode} to false
        set {pd.active.duration} to {@default_duration}
        # BUG 6 FIX: countdown defaults to option value, can be overridden
        set {_countdown} to {@countdown_seconds}
        delete {pd.active.region}
        delete {pd.active.lore_text}
        delete {pd.active.title}
        delete {pd.active.custom_reward}
        delete {pd.active.team1_spawn}
        delete {pd.active.team2_spawn}
        set {_title_set} to false
        set {_lore_set} to false
        set {_injury_override} to true
        set {_numindex} to 0
        # Collect all arguments — Skript handles quotes natively
        # "The Great War" becomes one arg, lore:"Heroes vs Villains" becomes lore:Heroes vs Villains
        delete {_arglist::*}
        set {_arglist::*} to arg-2, arg-3, arg-4, arg-5, arg-6, arg-7, arg-8, arg-9, arg-10, arg-11, arg-12, arg-13, arg-14, arg-15
        loop {_arglist::*}:
            if loop-value is set:
                if loop-value starts with "title:":
                    set {_t} to subtext of loop-value from character 7 to length of loop-value
                    replace all "_" with " " in {_t}
                    set {pd.active.title} to {_t}
                    set {_title_set} to true
                else if loop-value starts with "lore:":
                    set {_l} to subtext of loop-value from character 6 to length of loop-value
                    replace all "_" with " " in {_l}
                    set {pd.active.lore_text} to {_l}
                    set {_lore_set} to true
                else if loop-value starts with "rep:":
                    set {_r} to subtext of loop-value from character 5 to length of loop-value
                    set {pd.active.rep_reward} to {_r} parsed as integer
                else if loop-value starts with "xp:":
                    set {_x} to subtext of loop-value from character 4 to length of loop-value
                    set {pd.active.xp_reward} to {_x} parsed as integer
                else if loop-value starts with "bucks:" or loop-value starts with "b:":
                    if loop-value starts with "bucks:":
                        set {_b} to subtext of loop-value from character 7 to length of loop-value
                    else:
                        set {_b} to subtext of loop-value from character 3 to length of loop-value
                    set {pd.active.bucks_reward} to {_b} parsed as integer
                else if loop-value starts with "dur:":
                    set {_d} to subtext of loop-value from character 5 to length of loop-value
                    set {pd.active.duration} to {_d} parsed as integer
                else if loop-value starts with "time:":
                    set {_d} to subtext of loop-value from character 6 to length of loop-value
                    set {pd.active.duration} to {_d} parsed as integer
                # BUG 6 & 9 FIX: countdown parsing now correct
                else if loop-value starts with "countdown:":
                    set {_cd} to subtext of loop-value from character 11 to length of loop-value
                    set {_countdown} to {_cd} parsed as integer
                else if loop-value starts with "cd:":
                    set {_cd} to subtext of loop-value from character 4 to length of loop-value
                    set {_countdown} to {_cd} parsed as integer
                # BUG 6 FIX: injury flag
                else if loop-value starts with "injury:":
                    set {_injstr} to subtext of loop-value from character 8 to length of loop-value
                    if lowercase {_injstr} is "false" or lowercase {_injstr} is "off":
                        set {_injury_override} to false
                    else:
                        set {_injury_override} to true
                # RESPAWN MODE: If enabled, players respawn normally instead of going to spectator
                else if loop-value starts with "respawn:" or loop-value starts with "respawnmode:" or loop-value starts with "rm:":
                    set {_rmstr} to subtext of loop-value from (index of loop-value at ":" ) + 1 to length of loop-value
                    if lowercase {_rmstr} is "true" or lowercase {_rmstr} is "on" or {_rmstr} parsed as integer is 1:
                        set {pd.active.respawn_mode} to true
                    else:
                        set {pd.active.respawn_mode} to false
                else if loop-value starts with "region:":
                    set {_reg} to subtext of loop-value from character 8 to length of loop-value
                    set {pd.active.region} to {_reg}
                else if loop-value starts with "rewardmode:" or loop-value starts with "mode:":
                    set {_rm} to subtext of loop-value from (length of (first 1 of (split loop-value at ":"))) + 2 to length of loop-value
                    set {_rmode} to {_rm} parsed as integer
                    if {_rmode} is not set:
                        set {_rmode} to 1
                    if {_rmode} < 0 or {_rmode} > 4:
                        set {_rmode} to 1
                    set {pd.active.reward_mode} to {_rmode}
                # Plain numbers (legacy support) — position based
                # 1=rep, 2=xp, 3=bucks, 4=duration, 5=countdown
                else if loop-value parsed as integer is set:
                    add 1 to {_numindex}
                    if {_numindex} is 1:
                        set {pd.active.rep_reward} to loop-value parsed as integer
                    else if {_numindex} is 2:
                        set {pd.active.xp_reward} to loop-value parsed as integer
                    else if {_numindex} is 3:
                        set {pd.active.bucks_reward} to loop-value parsed as integer
                    else if {_numindex} is 4:
                        set {pd.active.duration} to loop-value parsed as integer
                    else if {_numindex} is 5:
                        set {_countdown} to loop-value parsed as integer
                else:
                    # FIX: Handle standalone on/off toggles after region is set
                    # First on/off = respawn mode, second on/off = injury
                    if {pd.active.region} is set:
                        set {_lowval} to lowercase loop-value
                        if {_lowval} is "on" or {_lowval} is "off":
                            if {_lowval} is "on":
                                set {_bool} to true
                            else:
                                set {_bool} to false
                            if {_respawn_toggle_set} is not true:
                                set {pd.active.respawn_mode} to {_bool}
                                set {_respawn_toggle_set} to true
                            else if {_injury_toggle_set} is not true:
                                set {_injury_override} to {_bool}
                                set {_injury_toggle_set} to true
                    # BUG FIX: If plain text without prefix, treat as TITLE (not region)
                    # Only if title hasn't been set via title: prefix
                    if {_title_set} is false:
                        set {pd.active.title} to loop-value
                        set {_title_set} to true
                    else if {pd.active.region} is not set:
                        set {pd.active.region} to loop-value
        # Guard: if duration somehow invalid, reset to default
        if {pd.active.duration} is not set:
            set {pd.active.duration} to {@default_duration}
        if {pd.active.duration} <= 0:
            set {pd.active.duration} to {@default_duration}
        if {_countdown} is not set:
            set {_countdown} to {@countdown_seconds}
        if {_countdown} <= 0:
            set {_countdown} to 5
        # Set up event state
        set {pd.active} to true
        set {pd.active.type} to {_type}
        set {pd.active.injury} to {_injury_override}
        set {pd.active.pvp} to true
        set {pd.active.phase} to "countdown"
        delete {pd.active.players::*}
        delete {pd.active.team1::*}
        delete {pd.active.team2::*}
        delete {pd.active.dead::*}
        delete {pd.active.vip}
        delete {pd.active.attackers::*}
        delete {pd.active.defenders::*}
        delete {pd.active.declined::*}
        delete {pd.active.kills::*}
        delete {pd.active.participants::*}
        set {pd.active.reward_mode} to 1
        # Restore pre-event settings only if not overridden by args
        if {_saved_title} is set:
            if {_title_set} is false:
                set {pd.active.title} to {_saved_title}
        if {_saved_lore} is set:
            if {_lore_set} is false:
                set {pd.active.lore_text} to {_saved_lore}
        if {_saved_reward} is set:
            set {pd.active.custom_reward} to {_saved_reward}
        if {_saved_t1spawn} is set:
            set {pd.active.team1_spawn} to {_saved_t1spawn}
        if {_saved_t2spawn} is set:
            set {pd.active.team2_spawn} to {_saved_t2spawn}
        # Confirm to admin
        set {_durmins} to floor({pd.active.duration} / 60)
        set {_dursecs} to {pd.active.duration}
        if {_durmins} < 1:
            set {_durdisplay} to "%{_dursecs}%s"
        else:
            set {_durdisplay} to "%{_durmins}% min"
        send "{@prefix}&aStarting &e%{_type}% &aevent!" to player
        if {pd.active.title} is set:
            send "{@prefix}&7Title: &e%{pd.active.title}%" to player
        set {_bucksdisplay} to ""
        if {pd.active.bucks_reward} > 0:
            set {_bucksdisplay} to " &7| Bucks: &e%{pd.active.bucks_reward}%"
        send "{@prefix}&7Duration: &e%{_durdisplay}% &7| Countdown: &e%{_countdown}%s &7| Rep: &e%{pd.active.rep_reward}% &7| XP: &e%{pd.active.xp_reward}%%{_bucksdisplay}%" to player
        # Launch countdown
        pdCountdown({_type}, true, {_countdown})

