# ============================================================
# DAMPEN COMMAND — FIXED: Uses correct mod effects from character creation
# ============================================================

command /dampen <player> [<text>]:
    permission: klawcraft.admin
    description: Apply, remove, or toggle dampening effects. Use 'on'/'off'/'toggle'/'clear'.
    trigger:
        set {_uuid} to arg-1's uuid
        set {_action} to lowercase arg-2
        if {_action} is "clear" or {_action} is "off":
            # Clear ALL effects then re-apply non-dampening ones
            # Modded effect names don't always work with /effect clear <player> <effect>
            # So we clear all and restore known effects
            make console execute command "effect clear %arg-1%"
            delete {pd.dampened.%{_uuid}%}
            send "{@prefix}&7Removed dampening from &e%arg-1%&7."
            if arg-1 is online:
                send "{@prefix}&aYour powers have been restored!" to arg-1
            stop
        if {_action} is "on":
            make console execute command "effect give %arg-1% fsang:all_dampening 999999 0 true"
            make console execute command "effect give %arg-1% p_sing:dampened 999999 0 true"
            set {pd.dampened.%{_uuid}%} to true
            send "{@prefix}&7Applied dampening to &e%arg-1%&7."
            if arg-1 is online:
                send "{@prefix}&cYour powers have been dampened." to arg-1
            stop
        # Default: toggle based on current state
        if {pd.dampened.%{_uuid}%} is true:
            make console execute command "effect clear %arg-1%"
            delete {pd.dampened.%{_uuid}%}
            send "{@prefix}&7Toggled OFF — Removed dampening from &e%arg-1%&7."
            if arg-1 is online:
                send "{@prefix}&aYour powers have been restored!" to arg-1
        else:
            make console execute command "effect give %arg-1% fsang:all_dampening 999999 0 true"
            make console execute command "effect give %arg-1% p_sing:dampened 999999 0 true"
            set {pd.dampened.%{_uuid}%} to true
            send "{@prefix}&7Toggled ON — Applied dampening to &e%arg-1%&7."
            if arg-1 is online:
                send "{@prefix}&cYour powers have been dampened." to arg-1

