command /pdteam <player> <integer>:
    permission: klawcraft.admin
    description: Assign a player to team 1 or 2 for Faction War
    trigger:
        if {pd.active} is not true:
            send "{@prefix}&cNo event is running."
            stop
        if {pd.active.type} is not "factionwar":
            send "{@prefix}&cThis only works during Faction War events."
            stop
        set {_uuid} to arg-1's uuid
        if arg-2 is 1:
            remove {_uuid} from {pd.active.team2::*}
            add {_uuid} to {pd.active.team1::*}
            if arg-1 is online:
                make console execute command "give %arg-1% minecraft:blue_banner{display:{Name:'\"\u00a79\u00a7lHero Banner\"',Lore:['\"\u00a77Team 1 - Heroes\"','\"\u00a77Fight for justice!\"','\"\u00a78Event Item - Returns after event\"']},pd_banner:1b,Unbreakable:1b,HideFlags:255} 1"
            send "{@prefix}&7Assigned &e%arg-1% &7to &9Team 1&7." to player
            send "{@event_prefix}&7You were assigned to &9Team 1&7!" to arg-1
        else if arg-2 is 2:
            remove {_uuid} from {pd.active.team1::*}
            add {_uuid} to {pd.active.team2::*}
            if arg-1 is online:
                make console execute command "give %arg-1% minecraft:red_banner{display:{Name:'\"\u00a7c\u00a7lVillain Banner\"',Lore:['\"\u00a77Team 2 - Villains\"','\"\u00a77Embrace the darkness!\"','\"\u00a78Event Item - Returns after event\"']},pd_banner:1b,Unbreakable:1b,HideFlags:255} 1"
            send "{@prefix}&7Assigned &e%arg-1% &7to &cTeam 2&7." to player
            send "{@event_prefix}&7You were assigned to &cTeam 2&7!" to arg-1
        else:
            send "{@prefix}&cTeam must be 1 or 2."

command /pdfactions:
    permission: klawcraft.admin
    description: Auto-assign faction war teams based on LuckPerms affiliation groups
    trigger:
        if {pd.active} is not true:
            send "{@prefix}&cNo event is running."
            stop
        if {pd.active.type} is not "factionwar":
            send "{@prefix}&cThis only works during Faction War events."
